#!/usr/bin/env bash
# tt â€” tmux team: per-project tmux session with a pi worker pool.
# See `tt --help` for the full reference.
set -euo pipefail

VERSION="0.13.1"
NATO=(alfa bravo charlie delta echo foxtrot golf hotel india juliett kilo lima
      mike november oscar papa quebec romeo sierra tango uniform victor whiskey
      xray yankee zulu)
PI_HISTORY_LIMIT=50000
# Tier registry: each tier bundles (model, thinking effort) into a named
# preset. Add a tier by adding a branch to tier_model()/tier_effort() and
# listing the name in PI_TIER_NAMES â€” nothing else needs to change. The
# default tier preserves prior behavior (deepseek-v4-flash at xhigh). Note
# that thinking effort is *fixed per tier* and cannot be set independently
# (`--low`/`--high`/`--xhigh` are rejected on `send`/`auto`).
PI_TIER_DEFAULT=deepseek
PI_TIER_NAMES="deepseek minimax"
PI_TIER_DEEPSEEK_MODEL="opencode-go/deepseek-v4-flash"
PI_TIER_DEEPSEEK_EFFORT=xhigh
PI_TIER_MINIMAX_MODEL="opencode-go/minimax-m3"
PI_TIER_MINIMAX_EFFORT=high

# Validate a tier name. Returns 0 for known tiers, 1 otherwise.
tier_is_known() {
  case $1 in
    deepseek|minimax) return 0 ;;
    *) return 1 ;;
  esac
}

# Resolve a tier name to its model provider (the `--model` value on the pi
# CLI, minus the `:effort` suffix). Falls back to the default tier for
# empty/unknown input so legacy `<cs>.tier` files and external state keep
# working.
tier_model() {
  case ${1:-$PI_TIER_DEFAULT} in
    deepseek) printf '%s' "$PI_TIER_DEEPSEEK_MODEL" ;;
    minimax)  printf '%s' "$PI_TIER_MINIMAX_MODEL"  ;;
    *)        printf '%s' "$PI_TIER_DEEPSEEK_MODEL" ;;
  esac
}

# Resolve a tier name to its thinking effort (the `:effort` suffix and the
# value passed to pi.setThinkingLevel). Same fallback rules.
tier_effort() {
  case ${1:-$PI_TIER_DEFAULT} in
    deepseek) printf '%s' "$PI_TIER_DEEPSEEK_EFFORT" ;;
    minimax)  printf '%s' "$PI_TIER_MINIMAX_EFFORT"  ;;
    *)        printf '%s' "$PI_TIER_DEEPSEEK_EFFORT" ;;
  esac
}
TT_STATE_DIR_BASE="${TT_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/tt}"
TT_DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/tt"
# TT_PI_AGENT_DIR is a legacy override kept for compatibility; prefer TT_PI_WORKER_DIR.
TT_PI_WORKER_DIR="${TT_PI_WORKER_DIR:-${TT_PI_AGENT_DIR:-$TT_DATA_DIR/pi-worker}}"
TT_REPO_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"

# Default orchestrator launch: resume the prior session, else start fresh.
# Used when `.tt/windows.json` does not override the `claude` window's command.
DEFAULT_CLAUDE_CMD='claude --continue --allow-dangerously-skip-permissions || claude --allow-dangerously-skip-permissions'

# jq program: read an optional <project>/.tt/windows.json and emit a normalized,
# defaults-applied window array `[{role,name,layout,panes:[{cmd,enter}]}]`.
# Absent/empty input ({}) yields the built-in default (dev + claude) â€” one code
# path serves both default and override. `$cc` carries DEFAULT_CLAUDE_CMD.
NORMALIZE_JQ='def norm: {cmd: (.cmd // ""), enter: (.enter != false)};
[ ( (.dev    // {}) | {role:"dev",    name:(.name // "dev"),    layout:(.layout // null), panes:((.panes // [{}])       | map(norm))} ),
  ( (.claude // {}) | {role:"claude", name:(.name // "claude"), layout:(.layout // null), panes:((.panes // [{cmd:$cc}]) | map(norm))} ) ]
+ ((.extra_windows // []) | map({role:"extra", name:.name, layout:(.layout // null), panes:((.panes // [{}]) | map(norm))}))'

# ---------- helpers ----------

die() { printf 'tt: %s\n' "$*" >&2; exit 1; }
note() { printf '[tt] %s\n' "$*" >&2; }

session_name() {
  local base hash
  base=$(basename "$PWD" | tr -c 'A-Za-z0-9_-' '-' | sed 's/-\{2,\}/-/g; s/^-//; s/-$//')
  hash=$(printf '%s' "$PWD" | sha1sum | cut -c1-4)
  printf '%s-%s' "$base" "$hash"
}

state_dir() {
  local d="$TT_STATE_DIR_BASE/$(session_name)"
  mkdir -p "$d"
  printf '%s' "$d"
}

session_exists() { tmux has-session -t "=$(session_name)" 2>/dev/null; }

# Enter the project session: switch-client when already inside tmux
# (attach refuses to nest), attach otherwise.
enter_session() {
  local win=${1:-}
  local target="=$(session_name)${win:+:$win}"
  if [[ -n "${TMUX:-}" ]]; then
    tmux switch-client -t "$target"
  else
    tmux attach -t "$target"
  fi
}

valid_callsign() {
  local n=$1; for i in "${NATO[@]}"; do [[ $i == "$n" ]] && return 0; done; return 1
}

cpu_count() { nproc 2>/dev/null || getconf _NPROCESSORS_ONLN 2>/dev/null || printf '4'; }

# Hard worker ceiling, enforced on every spawn path: cores-2, floored at 1
# and capped at 26 (NATO-letter exhaustion, `zulu`). The ceiling is the
# runaway backstop that keeps lazy/auto spawning safe.
pi_cap() {
  local c m; c=$(cpu_count); m=$((c - 2))
  (( m < 1 ))  && m=1
  (( m > 26 )) && m=26
  printf '%d' "$m"
}

# Number of pi worker windows that currently exist.
count_workers() {
  local n c=0
  for n in "${NATO[@]}"; do window_exists "pi-$n" && c=$((c + 1)); done
  printf '%d' "$c"
}

window_exists() {
  local name=$1
  tmux list-windows -t "=$(session_name)" -F '#W' 2>/dev/null | grep -Fxq "$name"
}

require_session() {
  session_exists || die "no session for $PWD; run \`tt up\` first"
}

set_session_version() {
  local s; s=$(session_name)
  tmux set-environment -t "=$s" TT_VERSION "$VERSION"
  printf '%s\n' "$VERSION" > "$(state_dir)/version"
}

# ---------- window config (.tt/windows.json) ----------
#
# `tt up` lays out FIXED windows (the orchestrator + dev/aux) from an optional
# per-project `<project>/.tt/windows.json`. The lazy `pi-*` worker pool is
# tt-owned and NOT configurable here. Every pane command is applied with a
# bare-shell guard (see pane_is_bare): a cmd is (re)sent only when the pane is
# currently a bare shell, so `tt up` is idempotent and reboots self-heal.
# Requires `jq`; without it tt falls back to the legacy dev+claude layout.

have_jq() { command -v jq >/dev/null 2>&1; }

# Normalized window array (memoized per process). Malformed config is ignored
# with a note; absent config yields the built-in default.
windows_config() {
  if [[ -z ${_TT_WIN_CFG+x} ]]; then
    local file="$PWD/.tt/windows.json"
    if [[ -f $file ]] && ! _TT_WIN_CFG=$(jq -c --arg cc "$DEFAULT_CLAUDE_CMD" "$NORMALIZE_JQ" < "$file" 2>/dev/null); then
      note "ignoring malformed $file; using built-in window layout"
      _TT_WIN_CFG=""
    fi
    [[ -n ${_TT_WIN_CFG:-} ]] || _TT_WIN_CFG=$(jq -c --arg cc "$DEFAULT_CLAUDE_CMD" "$NORMALIZE_JQ" <<<'{}')
  fi
  printf '%s' "$_TT_WIN_CFG"
}

win_field() { windows_config | jq -r ".[$1] | $2"; }                       # win_field <index> <jq>
configured_window_names()  { windows_config | jq -r '.[].name'; }
first_window_name()        { if have_jq; then windows_config | jq -r '.[0].name'; else printf 'dev'; fi; }
orchestrator_window_name() { if have_jq; then windows_config | jq -r 'map(select(.role=="claude"))[0].name // "claude"'; else printf 'claude'; fi; }

# Is the pane (targeted by pane_id) sitting at a bare shell? Mirrors the guard
# that kept claude-relaunch idempotent â€” pane_current_command is reliable here
# because we target a specific pane, not a grandchild-hosting pi window.
pane_is_bare() {
  local cmd; cmd=$(tmux display-message -t "$1" -p '#{pane_current_command}' 2>/dev/null) || return 1
  case "$cmd" in bash|zsh|sh|fish) return 0 ;; *) return 1 ;; esac
}

# Split a freshly-created window to its configured pane count and (re)send each
# pane's command, bare-shell-guarded. Heals at WINDOW granularity: a window that
# already has >1 pane is never re-split (a partially-closed window is left
# alone), but any bare-shell pane still gets its command re-sent.
apply_window_panes() {
  local i=$1 created=${2:-0} s; s=$(session_name)
  local name npanes
  name=$(win_field "$i" '.name')
  npanes=$(win_field "$i" '.panes | length')

  local -a pids
  mapfile -t pids < <(tmux list-panes -t "=$s:$name" -F '#{pane_id}' 2>/dev/null)
  (( ${#pids[@]} == 0 )) && return 0

  # Fresh single bare-shell window -> split up to the configured pane count.
  local did_split=0
  if (( ${#pids[@]} == 1 && npanes > 1 )) && pane_is_bare "${pids[0]}"; then
    local last="${pids[0]}" newid j
    for (( j=1; j<npanes; j++ )); do
      newid=$(tmux split-window -t "$last" -c "$PWD" -P -F '#{pane_id}' 2>/dev/null) || break
      last="$newid"
    done
    tmux select-layout -t "=$s:$name" "$(win_field "$i" '.layout // "even-horizontal"')" >/dev/null 2>&1 || true
    mapfile -t pids < <(tmux list-panes -t "=$s:$name" -F '#{pane_id}' 2>/dev/null)
    tmux select-pane -t "${pids[0]}" >/dev/null 2>&1 || true
    did_split=1
  fi

  # "Fresh" = panes born this invocation (cold session, new window, or just
  # split). On a fresh pane any command is sent. On a heal re-`up` only a RUN
  # command (enter:true) is resumed into a now-bare pane â€” a typed prefill
  # (enter:false) is NOT re-sent, else its buffer would be doubled.
  local fresh=0; (( ${_TT_COLD_START:-0} || created || did_split )) && fresh=1

  local lim=${#pids[@]}; (( npanes < lim )) && lim=$npanes
  local j cmd enter
  for (( j=0; j<lim; j++ )); do
    cmd=$(win_field "$i" ".panes[$j].cmd")
    [[ -n $cmd ]] || continue
    pane_is_bare "${pids[j]}" || continue
    enter=$(win_field "$i" ".panes[$j].enter")
    if [[ $enter == true ]]; then
      tmux send-keys -t "${pids[j]}" "$cmd" Enter
    elif (( fresh )); then
      tmux send-keys -t "${pids[j]}" "$cmd"
    fi
  done
}

# ---------- session lifecycle ----------

create_session() {
  local s; s=$(session_name)
  local _TT_COLD_START=1   # brand-new session: every pane is fresh (prefills fire once)
  tmux new-session -d -s "$s" -n "$(first_window_name)" -c "$PWD"
  set_session_version
  # set-option does not accept the `=` exact-match prefix; use the
  # bare-name + colon target form instead.
  tmux set-option -t "$s:" history-limit "$PI_HISTORY_LIMIT" >/dev/null
  ensure_standard_windows
  tmux select-window -t "=$s:$(orchestrator_window_name)"
}

# Collapse duplicate standard windows. A tmux-resurrect/continuum restore
# racing with `tt up` can recreate the session, leaving two `pi-bravo`
# windows etc.; a duplicated name makes every `tmux ... -t <name>` target
# ambiguous ("can't find window"). A duplicated pi window is dropped and
# respawned clean; for dev/claude one copy is kept (never the window tt
# is being run from). Only tt's own standard names are touched â€” ad-hoc
# user windows are left alone even if they collide.
dedup_windows() {
  local s; s=$(session_name)
  local cur; cur=$(tmux display-message -p '#{window_id}' 2>/dev/null) || cur=""
  local allwin
  allwin=$(tmux list-windows -t "=$s" -F '#{window_id} #{window_name}' 2>/dev/null) || return 0
  local -a stdnames
  if have_jq; then mapfile -t stdnames < <(configured_window_names); else stdnames=(dev claude); fi
  local name
  for name in "${stdnames[@]}" "${NATO[@]/#/pi-}"; do
    local -a ids=()
    ids=( $(printf '%s\n' "$allwin" | awk -v n="$name" '$2==n{print $1}') )
    (( ${#ids[@]} > 1 )) || continue
    note "collapsing ${#ids[@]} duplicate '$name' windows"
    local id
    if [[ $name == pi-* ]]; then
      for id in "${ids[@]}"; do tmux kill-window -t "$id" 2>/dev/null || true; done
      # Heal path: no --tier is set, so restore the default explicitly
      # before spawn_pi_window (which no longer writes the tier itself).
      printf '%s' "$PI_TIER_DEFAULT" > "$(state_dir)/${name#pi-}.tier"
      spawn_pi_window "${name#pi-}"
    else
      local kept=""
      for id in "${ids[@]}"; do
        if [[ -z $kept ]]; then kept=$id; continue; fi
        [[ $id == "$cur" ]] && continue
        tmux kill-window -t "$id" 2>/dev/null || true
      done
    fi
  done
}

# Bring the session to the standard layout. Idempotent â€” this is what
# makes `tt up` able to heal a session degraded by a crash, an aborted
# teardown, or a tmux-resurrect restore, not just build one from cold.
ensure_standard_windows() {
  local s; s=$(session_name)
  dedup_windows
  if ! have_jq; then
    # Legacy fallback (no jq): the historical dev + claude layout.
    window_exists dev    || tmux new-window -t "=$s:" -n dev    -c "$PWD"
    window_exists claude || tmux new-window -t "=$s:" -n claude -c "$PWD"
    [[ -f "$PWD/.tt/windows.json" ]] && note "jq not found; ignoring .tt/windows.json"
    legacy_launch_claude
    return 0
  fi
  local n i name created
  n=$(windows_config | jq 'length')
  for (( i=0; i<n; i++ )); do
    name=$(win_field "$i" '.name')
    if window_exists "$name"; then created=0; else tmux new-window -t "=$s:" -n "$name" -c "$PWD"; created=1; fi
    # Keep the name stable for window_exists even while a long-running command
    # (e.g. `pnpm dev`) would otherwise trigger tmux automatic-rename.
    tmux set-window-option -t "=$s:$name" automatic-rename off >/dev/null 2>&1 || true
    apply_window_panes "$i" "$created"
  done
}

spawn_pi_window() {
  local name=$1
  local s; s=$(session_name)
  tmux new-window -t "=$s:" -n "pi-$name" -c "$PWD"
  tmux set-window-option -t "=$s:pi-$name" automatic-rename off
  # Caller is responsible for writing the tier to <cs>.tier before
  # calling this â€” the file must reflect the desired tier so start_repl
  # launches the REPL with the right --model. (Heal paths in
  # ensure_standard_windows and `clear` write the default explicitly.)
  printf '0' > "$(state_dir)/$name.gen"
  : > "$(state_dir)/$name.tasks.jsonl"
  start_repl "$name"
}

up_cmd() {
  if session_exists; then
    set_session_version
    ensure_standard_windows   # heal any windows lost to a crash/aborted down
  else
    create_session
  fi
  # The orchestrator + dev/aux panes are (re)launched by ensure_standard_windows
  # via apply_window_panes (bare-shell-guarded). No pi workers are pre-spawned â€”
  # the pool is lazy: workers materialize on the first `tt pi send`/`auto`.
  printf '%s\n' "$PWD" > "$(state_dir)/project"
  # Already attached to this session â€” healing is done, nothing to switch to.
  if [[ -n "${TMUX:-}" ]] && [[ "$(tmux display-message -p '#S')" == "$(session_name)" ]]; then
    return 0
  fi
  enter_session "$(orchestrator_window_name)"
}

attach_cmd() {
  require_session
  enter_session
}

down_cmd() {
  require_session
  local s; s=$(session_name)
  local busy=()
  for n in "${NATO[@]}"; do
    window_exists "pi-$n" || continue
    [[ $(worker_state "$n") == busy ]] && busy+=("$n")
  done
  if (( ${#busy[@]} )); then
    printf 'tt: workers busy: %s\n' "${busy[*]}" >&2
    printf 'tt: their in-flight tasks will be lost.\n' >&2
  fi
  printf 'tt: kill session %s? [y/N] ' "$s" >&2
  local ans; read -r ans
  [[ $ans == y || $ans == Y ]] || return 0
  # SIGTERM each pi window's whole process group, then kill the window.
  # The group â€” wrapper bash, its `node`, and the `pi` grandchild that
  # hosts the tt-worker extension â€” all share the pane pid as PGID.
  # Killing a single pid would orphan the grandchild (reparented away,
  # it survives kill-session and leaks). `kill -- -PGID` gets them all.
  # `|| true`: tmux/kill exit non-zero if the window already vanished.
  for n in "${NATO[@]}"; do
    window_exists "pi-$n" || continue
    local pane_pid
    pane_pid=$(tmux display-message -p -t "=$s:pi-$n" '#{pane_pid}' 2>/dev/null) || true
    [[ -n $pane_pid ]] && kill -TERM -- "-$pane_pid" 2>/dev/null || true
    tmux kill-window -t "=$s:pi-$n" 2>/dev/null || true
  done
  sleep 0.5
  tmux kill-session -t "=$s" 2>/dev/null || true
  rm -rf "$(state_dir)"
}

# ---------- pi state ----------

current_tier() {
  # Returns the worker's tier NAME (not the thinking effort). Normalizes
  # legacy `xhigh`/empty values to the default tier so state dirs from
  # before the tier-preset era keep working without manual cleanup.
  local t
  t=$(cat "$(state_dir)/$1.tier" 2>/dev/null || true)
  if tier_is_known "$t"; then
    printf '%s' "$t"
  else
    printf '%s' "$PI_TIER_DEFAULT"
  fi
}
current_gen()  { cat "$(state_dir)/$1.gen"  2>/dev/null || printf '0'; }

bump_gen() {
  local name=$1 g
  g=$(current_gen "$name")
  printf '%d' $((g + 1)) > "$(state_dir)/$name.gen"
}

pi_session_dir() {
  local name=$1
  printf '%s/pi-sessions/%s/g%s' "$(state_dir)" "$name" "$(current_gen "$name")"
}

# Is the worker's pi REPL process alive? `pane_current_command` is
# unreliable here â€” pi runs as a grandchild (bash â†’ node â†’ pi) and tmux
# reports the foreground command inconsistently. Instead match the live
# pi process by its unique `--session-dir` path on the command line.
repl_running() {
  pgrep -f -- "$(state_dir)/pi-sessions/$1/" >/dev/null 2>&1
}

ensure_pi_worker_dir() {
  # pi treats PI_CODING_AGENT_DIR as writable config/state, so keep the worker
  # runtime dir real. Repo templates are linked/copied into it lazily.
  if [[ -L $TT_PI_WORKER_DIR && $(readlink -f "$TT_PI_WORKER_DIR" 2>/dev/null) == "$TT_REPO_DIR/pi-worker" ]]; then
    rm -f "$TT_PI_WORKER_DIR"
  fi
  mkdir -p "$TT_PI_WORKER_DIR/extensions"

  local meta="$TT_PI_WORKER_DIR/.tt-version"
  local prev_app_sha prev_ext_sha prev_settings_sha
  prev_app_sha=$(awk -F= '$1=="file.APPEND_SYSTEM.md.sha"{print $2}' "$meta" 2>/dev/null || true)
  prev_ext_sha=$(awk -F= '$1=="file.extensions/tt-worker.ts.sha"{print $2}' "$meta" 2>/dev/null || true)
  prev_settings_sha=$(awk -F= '$1=="file.settings.json.sha"{print $2}' "$meta" 2>/dev/null || true)

  local app_src="$TT_REPO_DIR/pi-worker/APPEND_SYSTEM.md"
  local app_dst="$TT_PI_WORKER_DIR/APPEND_SYSTEM.md"
  local app_sha; app_sha=$(sha256sum "$app_src" | awk '{print $1}')
  if [[ ! -e $app_dst || ( -L $app_dst && ! -e $app_dst ) ]]; then
    ln -sfn "$app_src" "$app_dst"
  elif [[ -L $app_dst && $(readlink -f "$app_dst" 2>/dev/null) == "$app_src" ]]; then
    ln -sfn "$app_src" "$app_dst"
  elif [[ -n $prev_app_sha && $prev_app_sha != "$app_sha" ]]; then
    note "pi-worker APPEND_SYSTEM.md template changed; keeping customized $app_dst (remove it to regenerate)"
  fi

  local ext_src="$TT_REPO_DIR/pi-worker/extensions/tt-worker.ts"
  local ext_dst="$TT_PI_WORKER_DIR/extensions/tt-worker.ts"
  local ext_sha; ext_sha=$(sha256sum "$ext_src" | awk '{print $1}')
  if [[ ! -e $ext_dst || ( -L $ext_dst && ! -e $ext_dst ) ]]; then
    ln -sfn "$ext_src" "$ext_dst"
  elif [[ -L $ext_dst && $(readlink -f "$ext_dst" 2>/dev/null) == "$ext_src" ]]; then
    ln -sfn "$ext_src" "$ext_dst"
  elif [[ -n $prev_ext_sha && $prev_ext_sha != "$ext_sha" ]]; then
    note "pi-worker tt-worker.ts template changed; keeping customized $ext_dst (remove it to regenerate)"
  fi

  local settings_src="$TT_REPO_DIR/pi-worker/settings.json"
  local settings_dst="$TT_PI_WORKER_DIR/settings.json"
  local settings_sha; settings_sha=$(sha256sum "$settings_src" | awk '{print $1}')
  local settings_preexisted=0
  [[ -e $settings_dst || -L $settings_dst ]] && settings_preexisted=1
  if [[ -L $settings_dst && $(readlink -f "$settings_dst" 2>/dev/null) == "$settings_src" ]]; then
    rm -f "$settings_dst"
    settings_preexisted=0
  fi
  if [[ ! -e $settings_dst ]]; then
    cp "$settings_src" "$settings_dst"
    settings_preexisted=0
  elif (( settings_preexisted )) && [[ -n $prev_settings_sha && $prev_settings_sha != "$settings_sha" ]]; then
    note "pi-worker settings.json template changed; keeping customized $settings_dst (remove it to regenerate)"
  fi

  local global_agent="${PI_CODING_AGENT_USER_DIR:-$HOME/.pi/agent}"
  local auth_dst="$TT_PI_WORKER_DIR/auth.json"
  if [[ -f $global_agent/auth.json ]]; then
    if [[ ! -e $auth_dst || ( -L $auth_dst && ! -e $auth_dst ) ]]; then
      ln -sfn "$global_agent/auth.json" "$auth_dst"
    elif [[ -f $auth_dst && ! -L $auth_dst && $(tr -d '[:space:]' < "$auth_dst" 2>/dev/null || true) == "{}" ]]; then
      rm -f "$auth_dst"
      ln -sfn "$global_agent/auth.json" "$auth_dst"
    fi
  fi
  local models_dst="$TT_PI_WORKER_DIR/models.json"
  if [[ -f $global_agent/models.json && ( ! -e $models_dst || ( -L $models_dst && ! -e $models_dst ) ) ]]; then
    ln -sfn "$global_agent/models.json" "$models_dst"
  fi

  local updated_at; updated_at=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  cat > "$meta" <<EOF
version=$VERSION
repo=$TT_REPO_DIR
file.APPEND_SYSTEM.md.sha=$app_sha
file.extensions/tt-worker.ts.sha=$ext_sha
file.settings.json.sha=$settings_sha
updated_at=$updated_at
EOF
}

# Start the pi REPL in the worker's window â€” non-blocking. `respawn-pane
# -k` kills whatever is there (a shell, or a stale/crashed pi) and starts
# fresh on the worker's current-generation session-dir. Workers use tt's
# private PI_CODING_AGENT_DIR so normal pi sessions do not load the
# tt-worker extension; TT_WORKER_CS/STATE wire it to this worker's control
# files. `; exec bash` keeps the pane alive
# (as a shell) if pi ever exits, so the window is never lost. The REPL
# boots in the background â€” `<cs>.starting` stamps the boot for
# `repl_starting`; readiness is awaited later by `wait_repl_ready`.
start_repl() {
  local name=$1 s sdir tier launch nice_prefix
  s=$(session_name)
  ensure_pi_worker_dir
  tier=$(current_tier "$name")
  sdir=$(pi_session_dir "$name"); mkdir -p "$sdir"
  # Reset the control channel for the fresh REPL: drop any pending queue
  # (a respawn means fresh context, so queued work is abandoned), the steer
  # channel, the last result, and the readiness marker.
  rm -f "$(state_dir)/$name.result" "$(state_dir)/$name.ready" \
        "$(state_dir)/$name.busy" \
        "$(state_dir)/$name.steer" "$(state_dir)/$name.steer.consuming"
  rm -rf "$(state_dir)/$name.queue"
  mkdir -p "$(state_dir)/$name.queue"
  local global_append="$TT_PI_WORKER_DIR/APPEND_SYSTEM.md"
  local append_flag=""
  if [[ ! -f "$PWD/.pi/APPEND_SYSTEM.md" && -f "$global_append" ]]; then
    append_flag="--append-system-prompt '$global_append'"
  fi
  # Run pi at low CPU/IO priority â€” claude is the interactive
  # orchestrator and must keep scheduler priority (so its TUI paints
  # without starving behind the concurrent pi `node` startups); pi
  # workers are background and API-I/O bound, so the nice costs them
  # little. The nice/ionice prefix wraps only the `env â€¦ pi â€¦` clause â€”
  # the `; exec bash` fallback shell stays at normal priority.
  nice_prefix="nice -n 19"
  command -v ionice >/dev/null 2>&1 && nice_prefix="ionice -c3 $nice_prefix"
  # Ephemeral workers (`tt pi auto --rm`) must not steal shared-pool work, or
  # they would never go idle to be reaped. The marker travels into the REPL
  # env so the extension's pump drains only this worker's own queue.
  local ephemeral_env=""
  [[ -f "$(state_dir)/$name.ephemeral" ]] && ephemeral_env="TT_WORKER_EPHEMERAL=1 "
  # Model + effort come from the worker's tier; the tier name is stored in
  # <cs>.tier and resolved through the tier_model/tier_effort helpers.
  local model_arg="$(tier_model "$tier"):$(tier_effort "$tier")"
  launch="$nice_prefix env PI_CODING_AGENT_DIR='$TT_PI_WORKER_DIR' \
TT_VERSION='$VERSION' TT_WORKER_CS=$name TT_WORKER_STATE='$(state_dir)' ${ephemeral_env}\
pi --session-dir '$sdir' --model $model_arg --no-skills${append_flag:+ $append_flag}; exec bash"
  tmux respawn-pane -k -t "=$s:pi-$name" -c "$PWD" "$launch"
  date +%s > "$(state_dir)/$name.starting"
}

# Is the worker's REPL within its boot window? `<cs>.starting` is stamped
# by start_repl; treat it as booting for 45s (a hair past wait_repl_ready's
# 40s deadline), after which a still-processless worker is genuinely down.
repl_starting() {
  local f="$(state_dir)/$1.starting" t
  [[ -f $f ]] || return 1
  t=$(cat "$f" 2>/dev/null) || return 1
  [[ -n $t ]] && (( $(date +%s) - t < 45 ))
}

# Block until the worker's REPL process is alive and the extension's
# queue pump + steer watch are live (`<cs>.ready`). Returns at once if ready.
wait_repl_ready() {
  local name=$1
  local deadline=$(( $(date +%s) + 40 ))
  while (( $(date +%s) < deadline )); do
    if repl_running "$name" && [[ -f "$(state_dir)/$name.ready" ]]; then
      return 0
    fi
    sleep 0.3
  done
  die "pi REPL failed to start on pi-$name"
}

# Ensure the worker's REPL is ready for a dispatch â€” the lazy wait.
# Re-starts only a genuinely-dead worker (not one still booting from
# `tt up`), then blocks for readiness.
ensure_repl_ready() {
  local name=$1
  if ! repl_running "$name" && ! repl_starting "$name"; then
    start_repl "$name"
  fi
  wait_repl_ready "$name"
}

# Legacy no-jq fallback: auto-launch claude in the claude window if the pane is
# a bare shell. The jq path handles this generically via apply_window_panes;
# this remains only for hosts without jq. Resumes (--continue) after reboot.
legacy_launch_claude() {
  local s; s=$(session_name)
  local cmd
  cmd=$(tmux display-message -t "=$s:claude" -p '#{pane_current_command}' 2>/dev/null) || return 0
  case "$cmd" in
    bash|zsh|sh|fish) ;;
    *) return 0 ;;
  esac
  tmux send-keys -t "=$s:claude" "$DEFAULT_CLAUDE_CMD" Enter
}

# Fields of a result file (written by the tt-worker extension). The *_file
# forms take a path so they serve both `<cs>.result` (the worker's latest-
# pointer) and the unified id-keyed store `results/<id>.result`.
result_head_file() {
  local f=$1 content id status
  [[ -f $f ]] || return 1
  content=$(cat "$f" 2>/dev/null) || return 1
  id=$(printf '%s\n' "$content" | sed -n 's/^id: //p' | head -n1)
  status=$(printf '%s\n' "$content" | sed -n 's/^status: //p' | head -n1)
  [[ -n $id ]] || id=-
  printf '%s %s\n' "$id" "$status"
}
result_text_file() { sed -n '/^---$/,$p' "$1" 2>/dev/null | sed '1d'; }
result_head() { result_head_file "$(state_dir)/$1.result"; }
result_text() { result_text_file "$(state_dir)/$1.result"; }
# The unified id-keyed store: every task (named `<cs>-<turn>` and pool
# `pool-<seq>`) records to `results/<id>.result`. `<cs>.result` is only the
# worker's latest-pointer, read by `worker_state`; per-id reads use these.
result_path_by_id() { printf '%s' "$(state_dir)/results/$1.result"; }
result_head_by_id() { result_head_file "$(state_dir)/results/$1.result"; }
result_text_by_id() { result_text_file "$(state_dir)/results/$1.result"; }

# A task id is `<callsign>-<turn>` or `pool-<seq>` â€” both match this; a bare
# callsign does not. Used to disambiguate `results`/`collect` targets.
is_task_id() { [[ $1 =~ ^[a-z]+-[0-9]+$ ]]; }

# Minimal JSON string escaper â€” no `jq` dependency, in keeping with the
# bash-only, no-JSON-parser ethos. Covers the characters that actually occur in
# result text (backslash, quote, the three whitespace controls).
json_escape() {
  local s=$1
  s=${s//\\/\\\\}; s=${s//\"/\\\"}
  s=${s//$'\n'/\\n}; s=${s//$'\t'/\\t}; s=${s//$'\r'/\\r}
  printf '%s' "$s"
}

# Pull the last `<field>: value` line from a result body â€” the WORKER_DONE /
# BLOCKED block is terminal, so `tail -n1` prefers it over any earlier prose.
result_field() { sed -n "s/^$2: //p" <<<"$1" | tail -n1; }

# --- observability helpers (status ELAPSED/QUEUE, result duration) -----------
# Whole seconds since a file's mtime (fails if absent). Times an in-flight turn
# from the `<cs>.busy` marker, which is stamped at turn start for EVERY turn kind
# (tracked task, stolen pool task, steer) â€” the one universal "working since"
# signal, since a pool steal never mirrors to `<cs>.result`.
secs_since_file() { local m; m=$(stat -c %Y "$1" 2>/dev/null) || return 1; printf '%s' $(( $(date +%s) - m )); }
# Format a second count as M:SS.
fmt_elapsed() { local s=${1:-0}; printf '%d:%02d' $(( s / 60 )) $(( s % 60 )); }
# Count queued (`<turn>.task`) files in a worker's own pinned queue dir â€” the
# same primitive the pool-pending line uses, applied per worker.
queue_depth() { find "$(state_dir)/$1.queue" -maxdepth 1 -name '*.task' 2>/dev/null | wc -l | tr -d ' '; }
# Echo "<started_at> <ended_at>" (epoch ints, empty when absent) from a result
# file's HEAD â€” the timestamps the extension stamps. One reader for both the
# --json envelope (duration_s) and the `tt pi results` DUR column.
result_times_file() {
  printf '%s %s' \
    "$(sed -n 's/^started_at: //p' "$1" 2>/dev/null | head -n1)" \
    "$(sed -n 's/^ended_at: //p' "$1" 2>/dev/null | head -n1)"
}
# M:SS wall-clock of a recorded task, or "-" when not both timestamps present
# (an older record or a still-running task). Used by `tt pi results`.
result_duration_file() {
  local sa ea; read -r sa ea <<<"$(result_times_file "$1")"
  [[ $sa =~ ^[0-9]+$ && $ea =~ ^[0-9]+$ ]] && { fmt_elapsed $(( ea - sa )); return; }
  printf '-'
}

# Emit one task's result as a JSON envelope. Parsed WORKER_DONE/BLOCKED fields
# are always present (empty when absent) for a stable schema; `text` (the raw
# body) is included only for other/error, where there is no structured block.
emit_result_json() {
  local id=$1 status=$2 text=$3 fc sm nt rs f sa="null" ea="null" dur="null"
  fc=$(result_field "$text" files_changed)
  sm=$(result_field "$text" summary)
  nt=$(result_field "$text" notes)
  rs=$(result_field "$text" reason)
  # started_at/ended_at live in the result HEAD (not the body) â€” read them from
  # the durable per-id store and derive duration_s. All `null` when absent (an
  # older record, or a still-running task with no end yet).
  f=$(result_path_by_id "$id")
  if [[ -f $f ]]; then
    local sa_raw ea_raw; read -r sa_raw ea_raw <<<"$(result_times_file "$f")"
    [[ $sa_raw =~ ^[0-9]+$ ]] && sa=$sa_raw
    [[ $ea_raw =~ ^[0-9]+$ ]] && ea=$ea_raw
    [[ $sa != null && $ea != null ]] && dur=$((ea - sa))
  fi
  printf '{"id":"%s","status":"%s","summary":"%s","files_changed":"%s","notes":"%s","reason":"%s","started_at":%s,"ended_at":%s,"duration_s":%s' \
    "$(json_escape "$id")" "$(json_escape "$status")" "$(json_escape "$sm")" \
    "$(json_escape "$fc")" "$(json_escape "$nt")" "$(json_escape "$rs")" \
    "$sa" "$ea" "$dur"
  case $status in
    other|error) printf ',"text":"%s"' "$(json_escape "$text")" ;;
  esac
  printf '}'
}

# A short one-line hint for `tt pi status` interrupted/blocked rows: the blocked
# reason or done summary if present, else the first non-empty line of the text.
result_reason_hint() {
  local text=$1 r
  r=$(result_field "$text" reason)
  [[ -z $r ]] && r=$(result_field "$text" summary)
  [[ -z $r ]] && r=$(grep -m1 -v '^[[:space:]]*$' <<<"$text" || true)
  printf '%s' "${r:0:80}"
}

last_task_row() {
  local f="$(state_dir)/$1.tasks.jsonl"
  [[ -s $f ]] || return 1
  tail -n1 "$f"
}

last_task_id() {
  local row id
  row=$(last_task_row "$1") || return 1
  id=$(printf '%s' "$row" | sed -n 's/.*"id":"\([^"]*\)".*/\1/p')
  [[ -n $id ]] || return 1
  printf '%s' "$id"
}

# State is derived from the worker's window + control files:
#   missing     â€” no window
#   starting    â€” REPL is within its boot window (process or queue pump
#                 not yet up); becomes idle/down once it settles
#   down        â€” window exists but the REPL process is not running
#   busy        â€” the `<cs>.busy` marker is set: the REPL is processing
#                 something (a tracked task, a stolen pool task, or a steer)
#   blocked     â€” not busy, and the worker's last assigned-task result is blocked
#   interrupted â€” not busy, and the last assigned-task result ended without a
#                 valid WORKER_DONE/BLOCKED footer or with an internal error;
#                 requires `tt pi clear` before the next dispatch
#   idle        â€” anything else
#
# `busy` keys off the marker, not the result file, because a stolen pool task
# is not mirrored to `<cs>.result` (it records only to `results/<id>.result`)
# and a steer records nothing â€” so the marker is the only reliable "is this REPL
# working" signal. blocked / interrupted are read from the worker's own
# `<cs>.result` latest-pointer once it is idle.
worker_state() {
  local name=$1
  window_exists "pi-$name" || { printf 'missing'; return; }
  if ! repl_running "$name"; then
    repl_starting "$name" && { printf 'starting'; return; }
    printf 'down'; return
  fi
  [[ -f "$(state_dir)/$name.ready" ]] || { printf 'starting'; return; }
  [[ -f "$(state_dir)/$name.busy" ]] && { printf 'busy'; return; }
  # Idle REPL: classify from its own last assigned-task result (if any).
  local tid; tid=$(last_task_id "$name") || { printf 'idle'; return; }
  local head rid rst
  head=$(result_head "$name") || { printf 'idle'; return; }
  if [[ $head == *' '* ]]; then rid=${head%% *}; rst=${head#* }; else rid=$head; rst=""; fi
  # A result for a different id (a pool/steer turn, or overwritten) does not
  # describe this worker's last assigned task â†’ treat as idle.
  [[ $tid == "$rid" ]] || { printf 'idle'; return; }
  case "$rst" in
    blocked)     printf 'blocked'     ;;
    other|error) printf 'interrupted' ;;
    *)           printf 'idle'        ;;
  esac
}

# Clearable / removable when not actively running a task.
ensure_idle_or_blocked() {
  [[ $(worker_state "$1") != busy ]]
}

# ---------- pi verbs ----------

pi_clear_cmd() {
  local name="" force=0
  while (( $# )); do
    case $1 in
      --force) force=1; shift ;;
      -*) die "unknown flag for clear: $1" ;;
      *)  [[ -z $name ]] && name=$1 || die "extra arg: $1"; shift ;;
    esac
  done
  [[ -n $name ]] || die "clear: callsign required"
  valid_callsign "$name" || die "invalid callsign: $name"
  require_session
  window_exists "pi-$name" || die "pi-$name does not exist"

  if (( ! force )) && ! ensure_idle_or_blocked "$name"; then
    die "pi-$name is busy; use --force to clear anyway"
  fi
  (( force )) && [[ $(worker_state "$name") == busy ]] && \
    note "interrupting running pi turn on pi-$name"
  bump_gen "$name"
  printf '{"clear":%d,"at":%d}\n' "$(current_gen "$name")" "$(date +%s)" >> "$(state_dir)/$name.tasks.jsonl"
  rm -f "$(state_dir)/$name".in.*.txt
  printf '%s' "$PI_TIER_DEFAULT" > "$(state_dir)/$name.tier"
  # Respawn the REPL on the new generation's session-dir â†’ fresh context.
  # Non-blocking; the next `tt pi send` waits for readiness lazily.
  start_repl "$name"
  note "pi-$name cleared (gen $(current_gen "$name"))"
}

# Recover an interrupted worker WITHOUT a context wipe (vs `clear`, which
# respawns on a fresh session-dir and loses context). `resume` re-drives the
# interrupted task to completion: interrupted â†’ busy â†’ done. The live REPL keeps
# all its context â€” that is the point â€” so it must still be running (never
# respawn here). The extension rehydrates the pending task id/nonce from the
# `<cs>.resume` trigger and re-sends the turn; the normal completion validator
# closes it.
pi_resume_cmd() {
  local name=""
  while (( $# )); do
    case $1 in
      -*) die "unknown flag for resume: $1" ;;
      *)  [[ -z $name ]] && name=$1 || die "extra arg: $1"; shift ;;
    esac
  done
  [[ -n $name ]] || die "resume: callsign required"
  valid_callsign "$name" || die "invalid callsign: $name"
  require_session
  window_exists "pi-$name" || die "pi-$name does not exist"
  repl_running "$name" || \
    die "pi-$name REPL is not running; resume needs its live context (use \`tt pi clear $name\` to start fresh)"
  local st; st=$(worker_state "$name")
  [[ $st == interrupted ]] || die "pi-$name is $st, not interrupted â€” nothing to resume"
  # Presence of the trigger is the whole signal; write it atomically.
  local rf="$(state_dir)/$name.resume"
  printf '%s' "$(date +%s)" > "$rf.tmp" && mv "$rf.tmp" "$rf"
  note "pi-$name resuming its interrupted task (context preserved); join with \`tt pi wait $name\`"
}

pi_send_cmd() {
  local name="" req_tier="" src="" notify=0
  while (( $# )); do
    case $1 in
      # Thinking effort is fixed per tier â€” the legacy effort flags are
      # rejected. Users who want a different model pick --tier=<name> instead.
      --low|--medium|--high|--xhigh) die "thinking effort is fixed per tier â€” use --tier=<name> (one of: $PI_TIER_NAMES) instead of the $1 flag" ;;
      --tier)   shift; req_tier=$1; shift ;;
      --tier=*) req_tier=${1#--tier=}; shift ;;
      --notify) notify=1;        shift ;;
      -)        src=-;           shift ;;
      -*)       die "unknown flag for send: $1" ;;
      *)
        if [[ -z $name ]]; then name=$1
        elif [[ -z $src ]]; then src=$1
        else die "extra arg: $1"; fi
        shift ;;
    esac
  done
  # Validate --tier only when the user actually passed it; an empty
  # req_tier falls back to the worker's current tier later in this fn.
  if [[ -n $req_tier ]] && ! tier_is_known "$req_tier"; then
    die "unknown --tier '$req_tier' (valid: $PI_TIER_NAMES)"
  fi
  [[ -n $name ]] || die "send: callsign required"
  [[ -n $src ]]  || die "send: prompt source required (file path or -)"
  if [[ $src != - && ! -r $src ]]; then
    die "send: '$src' is not a readable file. Source must be a FILE path or '-' for stdin.
  echo text:   printf 'TASK: ...\n' | tt pi send <callsign> -
  from a file: tt pi send <callsign> ./task.txt"
  fi
  valid_callsign "$name" || die "invalid callsign: $name"
  require_session
  # Tier-change guard: refuse if the worker already exists on a different
  # tier. The REPL is launched with --model baked into the command line,
  # so changing the tier on a running worker would silently swap the
  # thinking effort via setThinkingLevel while leaving the model stale.
  # Use `tt pi clear <cs>` to respawn on the new tier (loses context).
  if [[ -n $req_tier ]] && window_exists "pi-$name"; then
    local cur_tier; cur_tier=$(current_tier "$name")
    if [[ $req_tier != "$cur_tier" ]]; then
      die "tier change on running worker requires \`tt pi clear $name\` (respawns the REPL; loses context); current tier '$cur_tier', requested '$req_tier'"
    fi
  fi
  # Write the requested tier to <cs>.tier BEFORE any spawn work, so a
  # fresh REPL launches with the right model. (Empty req_tier = no-op;
  # the worker keeps its current tier, written by spawn_pi_window.)
  if [[ -n $req_tier ]]; then
    printf '%s' "$req_tier" > "$(state_dir)/$name.tier"
  fi
  # Lazy spawn: a send to an absent worker brings it up (under the cap)
  # rather than erroring â€” the orchestrator never has to `add` first.
  if ! window_exists "pi-$name"; then
    local cap; cap=$(pi_cap)
    (( $(count_workers) >= cap )) && \
      die "pi worker cap of $cap reached (cores-2, max 26)"
    spawn_pi_window "$name"
  fi

  # Reasoning effort is a runtime knob: the tier travels in the queued task
  # and the tt-worker extension applies it via setThinkingLevel â€” no
  # respawn, pi context is preserved. ensure_repl_ready waits for the
  # REPL to be ready (relaunching only one that has actually died), so a
  # send issued while `tt up`'s background boot is still in flight just
  # blocks here until the worker is up.
  local cur_tier; cur_tier=$(current_tier "$name")
  local tier="${req_tier:-$cur_tier}"
  ensure_repl_ready "$name"

  # A busy worker no longer refuses â€” the task is appended to the worker's
  # queue and runs when the current turn ends (`send` = run-next; use
  # `tt pi steer` for run-now). An interrupted worker still needs an
  # explicit clear: its context is suspect.
  [[ $(worker_state "$name") == interrupted ]] && \
    die "pi-$name has an interrupted task; run \`tt pi clear $name\` first"

  enqueue_to_worker "$name" "$tier" "$src" "$notify"
}

# Assign id `<name>-<turn>`, persist the prompt (+nonce), log the task, and
# append it to the worker's own queue dir; echo the id. Assumes pi-<name> is
# ready. Shared by `send` and the worker-assigned path of `auto`. Each queue
# file is line 1 = `<task id> <tier> <nonce>`, remainder = prompt body; the
# extension validates nonce + terminal-position on agent_end.
enqueue_to_worker() {
  local name=$1 tier=$2 src=$3 notify=${4:-0}
  local f="$(state_dir)/$name.tasks.jsonl"
  local turn=1
  [[ -s $f ]] && turn=$(($(wc -l <"$f") + 1))
  local id="$name-$turn"
  local nonce; nonce=$(openssl rand -hex 8)

  local promptfile="$(state_dir)/$name.in.$turn.txt"
  if [[ $src == - ]]; then cat > "$promptfile"; else cp "$src" "$promptfile"; fi
  printf '\nnonce: %s\n' "$nonce" >> "$promptfile"

  printf '{"turn":%d,"id":"%s","sent_at":%d,"tier":"%s","nonce":"%s","notify":%d}\n' \
    "$turn" "$id" "$(date +%s)" "$tier" "$nonce" "$notify" >> "$f"

  local nfield=""; [[ $notify == 1 ]] && nfield=" notify"
  local qdir="$(state_dir)/$name.queue"
  mkdir -p "$qdir"
  local qf="$qdir/$turn.task"
  { printf '%s %s %s%s\n' "$id" "$tier" "$nonce" "$nfield"; cat "$promptfile"; } > "$qf.tmp"
  mv "$qf.tmp" "$qf"

  printf '%s\n' "$id"
}

# Tear down any ephemeral (`tt pi auto --rm`) worker that has gone idle with an
# empty queue â€” its one-shot job (and any pinned follow-ups) is done. Daemonless:
# swept opportunistically by auto/status, and on the worker's own `wait`.
# Ephemeral workers never steal pool work (see start_repl), so they reliably
# reach idle.
reap_ephemeral_workers() {
  local n
  for n in "${NATO[@]}"; do
    [[ -f "$(state_dir)/$n.ephemeral" ]] || continue
    if ! window_exists "pi-$n"; then
      rm -rf "$(state_dir)/$n."* "$(state_dir)/pi-sessions/$n"
      continue
    fi
    [[ $(worker_state "$n") == idle ]] || continue
    # leave pinned follow-ups (named `send`s) to drain first
    compgen -G "$(state_dir)/$n.queue/*.task" >/dev/null 2>&1 && continue
    tmux kill-window -t "=$(session_name):pi-$n" 2>/dev/null || true
    rm -rf "$(state_dir)/$n."* "$(state_dir)/pi-sessions/$n"
  done
}

# Pick a worker for a task with no explicit callsign and dispatch it:
#   reuse an idle worker â†’ else spawn one (under the cap) â†’ else queue it on the
# shared pool, where the first worker to go idle steals it. With --rm, instead
# spawn a fresh EPHEMERAL worker that is torn down once its task (and any pinned
# follow-ups) finishes. The chosen worker is echoed to stderr ("using pi-<cs>");
# the task-id goes to stdout so `TID=$(tt pi auto â€¦)` captures just the id.
# One structured line for `tt pi auto --json`: which worker took the task and how
# it was placed (`idle` reuse / fresh `spawn` / `pool` queue / `ephemeral` --rm).
# `routed` reports the ACTUAL placement, so a --prefer-fresh that fell back at the
# cap honestly reads `idle`/`pool`.
emit_auto_json() {
  local worker=$1 tid=$2 routed=$3
  printf '{"worker":"%s","task_id":"%s","routed":"%s"}\n' \
    "$(json_escape "$worker")" "$(json_escape "$tid")" "$routed"
}

pi_auto_cmd() {
  local req_tier="" src="" rm_flag=0 notify=0 json=0 prefer_fresh=0
  while (( $# )); do
    case $1 in
      --low|--medium|--high|--xhigh) die "thinking effort is fixed per tier â€” use --tier=<name> (one of: $PI_TIER_NAMES) instead of the $1 flag" ;;
      --tier)   shift; req_tier=$1; shift ;;
      --tier=*) req_tier=${1#--tier=}; shift ;;
      --rm)           rm_flag=1;       shift ;;
      --notify)       notify=1;        shift ;;
      --json)         json=1;          shift ;;
      --prefer-fresh) prefer_fresh=1;  shift ;;
      -)              src=-;           shift ;;
      -*)             die "unknown flag for auto: $1" ;;
      *)              [[ -z $src ]] && src=$1 || die "extra arg: $1"; shift ;;
    esac
  done
  # Validate --tier only when the user actually passed it; an empty
  # req_tier falls back to the worker's current tier later in this fn.
  if [[ -n $req_tier ]] && ! tier_is_known "$req_tier"; then
    die "unknown --tier '$req_tier' (valid: $PI_TIER_NAMES)"
  fi
  [[ -n $src ]] || die "auto: prompt source required (file path or -)"
  if [[ $src != - && ! -r $src ]]; then
    die "auto: '$src' is not a readable file. Source must be a FILE path or '-' for stdin."
  fi
  require_session
  reap_ephemeral_workers

  # --rm: a fresh ephemeral worker, never a reuse (the whole point is a clean
  # one-shot that is destroyed after).
  if (( rm_flag )); then
    local cap; cap=$(pi_cap)
    (( $(count_workers) < cap )) || \
      die "auto --rm: worker cap of $cap reached; free one (tt pi rm) or wait"
    local chosen="" n
    for n in "${NATO[@]}"; do
      window_exists "pi-$n" || { chosen=$n; break; }
    done
    [[ -n $chosen ]] || die "auto --rm: no free callsign available"
    : > "$(state_dir)/$chosen.ephemeral"   # marker â†’ start_repl sets TT_WORKER_EPHEMERAL
    # Write the requested tier (or default) before spawn so the REPL
    # launches with the right model. spawn_pi_window's own tier write
    # is skipped because the file is already correct.
    printf '%s' "${req_tier:-$PI_DEFAULT_TIER}" > "$(state_dir)/$chosen.tier"
    spawn_pi_window "$chosen"
    local tier="${req_tier:-$PI_DEFAULT_TIER}"
    ensure_repl_ready "$chosen"
    local tid; tid=$(enqueue_to_worker "$chosen" "$tier" "$src" "$notify")
    if (( json )); then emit_auto_json "$chosen" "$tid" ephemeral
    else note "using pi-$chosen (ephemeral)"; printf '%s\n' "$tid"; fi
    return 0
  fi

  local chosen="" routed="" n
  # --prefer-fresh: spawn a NEW worker before reusing an idle one â€” eager
  # parallelism and a clean pi context (a reused idle worker still carries its
  # previous task's context). Only under the cap; at cap it falls through to
  # reuse/pool below, so the ceiling is never exceeded.
  if (( prefer_fresh )) && (( $(count_workers) < $(pi_cap) )); then
    for n in "${NATO[@]}"; do
      window_exists "pi-$n" || { chosen=$n; 
        # Apply tier (or default) before spawn so the REPL launches on
        # the right model.
        printf '%s' "${req_tier:-$PI_DEFAULT_TIER}" > "$(state_dir)/$n.tier"
        spawn_pi_window "$n"; routed=spawn; break; }
    done
  fi
  # Reuse the first idle worker (NATO order). If --tier is set, skip
  # workers whose current tier doesn't match â€” reusing them would mean
  # the new task runs on the wrong model (the REPL was launched with
  # --model baked in).
  if [[ -z $chosen ]]; then
    for n in "${NATO[@]}"; do
      window_exists "pi-$n" || continue
      [[ $(worker_state "$n") == idle ]] || continue
      if [[ -n $req_tier ]]; then
        local nt; nt=$(current_tier "$n")
        [[ $nt == "$req_tier" ]] || continue
      fi
      chosen=$n; routed=idle; break
    done
  fi
  # None idle but room under the cap â†’ spawn the next free callsign.
  if [[ -z $chosen ]] && (( $(count_workers) < $(pi_cap) )); then
    for n in "${NATO[@]}"; do
      window_exists "pi-$n" || { chosen=$n;
        printf '%s' "${req_tier:-$PI_DEFAULT_TIER}" > "$(state_dir)/$n.tier"
        spawn_pi_window "$n"; routed=spawn; break; }
    done
  fi

  if [[ -n $chosen ]]; then
    # (The tier file was set before spawn above; no need to write again.)
    local tier; tier=$(current_tier "$chosen")
    ensure_repl_ready "$chosen"
    local tid; tid=$(enqueue_to_worker "$chosen" "$tier" "$src" "$notify")
    if (( json )); then emit_auto_json "$chosen" "$tid" "$routed"
    else note "using pi-$chosen"; printf '%s\n' "$tid"; fi
    return 0
  fi

  # No compatible worker is free. If --tier was set, refuse â€” a pool
  # task can only be claimed by whichever worker frees next, and that
  # worker might not be on the requested tier. The user can free a
  # worker or use `tt pi send <cs> --tier NAME` to force a fresh worker
  # (refused at cap, so under-cap dispatch is the safe path).
  if [[ -n $req_tier ]]; then
    die "auto --tier $req_tier: no compatible worker (all on different tiers or busy at cap); free a worker (\`tt pi rm <cs>\`) or use \`tt pi send <cs> --tier $req_tier\` to force a fresh worker"
  fi

  # Everyone exists and is busy at the cap â†’ shared pool queue.
  local tier="${req_tier:-$PI_DEFAULT_TIER}"
  local pooldir="$(state_dir)/queue"; mkdir -p "$pooldir"
  local seqf="$(state_dir)/pool.seq" seq=1
  [[ -f $seqf ]] && seq=$(($(cat "$seqf") + 1))
  printf '%d' "$seq" > "$seqf"
  local id="pool-$seq"
  local nonce; nonce=$(openssl rand -hex 8)
  local promptfile="$(state_dir)/pool.$seq.txt"
  if [[ $src == - ]]; then cat > "$promptfile"; else cp "$src" "$promptfile"; fi
  printf '\nnonce: %s\n' "$nonce" >> "$promptfile"
  local nfield=""; [[ $notify == 1 ]] && nfield=" notify"
  local qf="$pooldir/$seq.task"
  { printf '%s %s %s%s\n' "$id" "$tier" "$nonce" "$nfield"; cat "$promptfile"; } > "$qf.tmp"
  mv "$qf.tmp" "$qf"
  if (( json )); then
    emit_auto_json "" "$id" pool
  else
    note "all workers busy at cap ($(pi_cap)); queued $id â€” the next idle worker claims it"
    printf '%s\n' "$id"
  fi
}

# Wait on a shared-pool task by its `pool-<seq>` id. Its result lives in the
# unified `results/` store, written by whichever worker stole it. No stuck guard:
# a pool task legitimately waits for a worker to free up (bound it with --timeout).
pi_wait_pool() {
  local id=$1 timeout=$2 json=${3:-0}
  require_session
  local prf; prf=$(result_path_by_id "$id")
  local deadline=0; (( timeout > 0 )) && deadline=$(($(date +%s) + timeout))
  while true; do
    local head rid rst
    head=$(result_head_file "$prf") || head=""
    if [[ -n $head ]]; then
      if [[ $head == *' '* ]]; then rid=${head%% *}; rst=${head#* }; else rid=$head; rst=""; fi
      if [[ $rid == "$id" ]]; then
        case "$rst" in
          done|blocked)
            if (( json )); then emit_result_json "$id" "$rst" "$(result_text_file "$prf")"; printf '\n'
            else result_text_file "$prf"; fi
            return 0 ;;
          error)
            (( json )) && { emit_result_json "$id" error "$(result_text_file "$prf")"; printf '\n'; exit 1; }
            result_text_file "$prf" >&2; die "pool task $id reported an internal error" ;;
          other)
            (( json )) && { emit_result_json "$id" other "$(result_text_file "$prf")"; printf '\n'; exit 1; }
            result_text_file "$prf" >&2; die "pool task $id finished without WORKER_DONE/BLOCKED (text above)" ;;
        esac
      fi
    fi
    deadline_expired "$deadline" && die "wait timeout for $id (${timeout}s)"
    sleep 1
  done
}

pi_wait_cmd() {
  local name="" task_id="" timeout=0 json=0
  while (( $# )); do
    case $1 in
      --timeout)
        shift; [[ $# -gt 0 ]] || die "wait: --timeout requires seconds"
        valid_timeout_arg "wait" "$1"; timeout=$1; shift ;;
      --json) json=1; shift ;;
      -*) die "unknown flag for wait: $1" ;;
      *)
        if [[ -z $name ]]; then name=$1
        elif [[ -z $task_id ]]; then task_id=$1
        else die "extra arg: $1"; fi
        shift ;;
    esac
  done
  [[ -n $name ]] || die "wait: callsign (or 'all') required"
  # `all` is a pseudo-callsign meaning every busy worker â€” fan-out join.
  if [[ $name == all ]]; then
    [[ -z $task_id ]] || die "wait all: a task-id cannot be combined with 'all'"
    local -a a=(); (( json )) && a+=(--json); (( timeout > 0 )) && a+=(--timeout "$timeout")
    pi_wait_all_cmd "${a[@]}"; return $?
  fi
  # A pool task id is its own handle (results live in the unified store).
  if [[ $name == pool-* ]]; then
    [[ -z $task_id ]] || die "wait: a pool id takes no second argument"
    pi_wait_pool "$name" "$timeout" "$json"; return $?
  fi
  # Accept a bare task-id (`alfa-3`) as the sole argument â€” the callsign is
  # embedded, so `tt pi wait $(tt pi auto â€¦)` just works.
  if [[ -z $task_id && $name == *-* ]]; then
    local _cs="${name%-*}" _turn="${name##*-}"
    if [[ $_turn =~ ^[0-9]+$ ]] && valid_callsign "$_cs"; then
      task_id=$name; name=$_cs
    fi
  fi
  valid_callsign "$name" || die "invalid callsign: $name"
  require_session
  window_exists "pi-$name" || die "pi-$name does not exist"

  # Task-id is optional: default to the worker's latest dispatch.
  if [[ -z $task_id ]]; then
    task_id=$(last_task_id "$name") || die "wait: pi-$name has no task to wait on"
  fi
  local expected_callsign="${task_id%-*}"
  [[ $expected_callsign == "$name" ]] || die "task-id callsign mismatch ($expected_callsign vs $name)"

  # Block until the tt-worker extension records this task's result.
  local deadline=0
  (( timeout > 0 )) && deadline=$(($(date +%s) + timeout))
  local turn="${task_id#*-}"
  local qf="$(state_dir)/$name.queue/$turn.task"
  local stuck_since=0
  while true; do
    local head="" rid="" rst=""
    # Read the unified per-id store, so waiting on an OLDER task-id (whose
    # `<cs>.result` latest-pointer has since been overwritten) still resolves.
    head=$(result_head_by_id "$task_id") || true
    if [[ -n $head ]]; then
      if [[ $head == *' '* ]]; then rid=${head%% *}; rst=${head#* }; else rid=$head; rst=""; fi
      if [[ $rid == "$task_id" ]]; then
        case "$rst" in
          done|blocked)
            if (( json )); then emit_result_json "$task_id" "$rst" "$(result_text_by_id "$task_id")"; printf '\n'
            else result_text_by_id "$task_id"; fi
            # Reap promptly if this was an ephemeral (`--rm`) worker's last task.
            [[ -f "$(state_dir)/$name.ephemeral" ]] && reap_ephemeral_workers
            return 0
            ;;
          error)
            if (( json )); then
              emit_result_json "$task_id" error "$(result_text_by_id "$task_id")"; printf '\n'; exit 1
            fi
            result_text_by_id "$task_id" >&2
            die "pi-$name reported an internal error for $task_id"
            ;;
          other)
            if (( json )); then
              emit_result_json "$task_id" other "$(result_text_by_id "$task_id")"; printf '\n'; exit 1
            fi
            result_text_by_id "$task_id" >&2
            die "pi finished $task_id without WORKER_DONE/BLOCKED (text above)"
            ;;
        esac
      fi
    fi
    repl_running "$name" \
      || die "pi REPL on pi-$name stopped before $task_id completed"
    # Stuck guard: our task is still sitting in the queue while the worker is
    # NOT running anything â€” a dead pump / watch. If it is running another
    # task (an earlier queue entry), queuing is legitimate, so reset the timer.
    if [[ -e $qf ]]; then
      if [[ $rst == running ]]; then
        stuck_since=0
      else
        (( stuck_since == 0 )) && stuck_since=$(date +%s)
        (( $(date +%s) - stuck_since >= 20 )) && \
          die "pi-$name never picked up $task_id (worker idle but task still queued; pump/watch dead)"
      fi
    else
      stuck_since=0
    fi
    deadline_expired "$deadline" && die "wait timeout for $task_id (${timeout}s)"
    sleep 1
  done
}

# Join primitive: block until several workers reach a terminal result, then
# print one consolidated report. With no callsigns, the target set is every
# worker currently busy. Each target is anchored on its latest dispatch
# (`last_task_id`), so `wait-all` means "wait for whatever each worker is
# doing right now". Exit 0 only if every target finished done/blocked.
# This is the fan-out join that keeps a multi-worker dispatch O(1) in the
# orchestrator's context instead of one `wait` round-trip per worker.
# After a busy-now `wait all`, point at `collect` if any NON-busy worker holds a
# terminal result past its collect cursor â€” i.e. it finished BEFORE the join and
# was therefore skipped. A pure signal on stderr; never changes wait-all's
# result or stdout. Args: callsigns already joined (excluded from the scan).
note_uncollected_skip() {
  local -A joined=(); local a; for a in "$@"; do joined[$a]=1; done
  local skipped=0 n
  for n in "${NATO[@]}"; do
    window_exists "pi-$n" || continue
    [[ -n ${joined[$n]:-} ]] && continue
    [[ $(worker_state "$n") == busy ]] && continue
    local cursor; cursor=$(cat "$(state_dir)/$n.collected" 2>/dev/null || printf 0)
    [[ $cursor =~ ^[0-9]+$ ]] || cursor=0
    local lt turn head rst
    lt=$(last_task_id "$n" 2>/dev/null) || continue
    turn=${lt##*-}; [[ $turn =~ ^[0-9]+$ ]] || continue
    (( turn > cursor )) || continue
    head=$(result_head_by_id "$lt" 2>/dev/null || true)
    rst=${head#* }; [[ $rst == "$head" ]] && rst=""
    case "$rst" in done|blocked|other|error) skipped=$((skipped+1)) ;; esac
  done
  (( skipped > 0 )) && note "wait-all: $skipped finished worker(s) not shown â€” 'tt pi collect' to include them"
  return 0
}

pi_wait_all_cmd() {
  local timeout=0 json=0; local -a names=()
  while (( $# )); do
    case $1 in
      --timeout)
        shift; [[ $# -gt 0 ]] || die "wait-all: --timeout requires seconds"
        valid_timeout_arg "wait-all" "$1"; timeout=$1; shift ;;
      --json) json=1; shift ;;
      -*) die "unknown flag for wait-all: $1" ;;
      *)  valid_callsign "$1" || die "invalid callsign: $1"; names+=("$1"); shift ;;
    esac
  done
  require_session

  # Default target set: every existing worker that is currently busy.
  if (( ${#names[@]} == 0 )); then
    local n
    for n in "${NATO[@]}"; do
      window_exists "pi-$n" || continue
      [[ $(worker_state "$n") == busy ]] && names+=("$n")
    done
  fi
  if (( ${#names[@]} == 0 )); then
    note_uncollected_skip
    (( json )) && { printf '[]\n'; return 0; }
    note "wait-all: no busy workers"
    return 0
  fi

  # Resolve each target's task id (its latest dispatch) up front.
  local -a tids=() pend=() statuses=() texts=()
  local i
  for i in "${!names[@]}"; do
    local nm=${names[i]} tid
    window_exists "pi-$nm" || die "pi-$nm does not exist"
    tid=$(last_task_id "$nm") || die "pi-$nm has no task to wait on"
    tids[i]=$tid; pend[i]=1
  done

  local deadline=0
  (( timeout > 0 )) && deadline=$(($(date +%s) + timeout))
  local rc=0

  while true; do
    local remaining=0
    for i in "${!names[@]}"; do
      (( ${pend[i]} )) || continue
      local nm=${names[i]} tid=${tids[i]} head rid rst
      head=$(result_head_by_id "$tid") || head=""
      if [[ -n $head ]]; then
        if [[ $head == *' '* ]]; then rid=${head%% *}; rst=${head#* }; else rid=$head; rst=""; fi
        if [[ $rid == "$tid" ]]; then
          case "$rst" in
            done|blocked) statuses[i]=$rst;  texts[i]=$(result_text_by_id "$tid"); pend[i]=0; continue ;;
            error)        statuses[i]=error; texts[i]=$(result_text_by_id "$tid"); pend[i]=0; rc=1; continue ;;
            other)        statuses[i]=other; texts[i]=$(result_text_by_id "$tid"); pend[i]=0; rc=1; continue ;;
          esac
        fi
      fi
      if ! repl_running "$nm"; then
        statuses[i]=down; texts[i]="(pi REPL stopped before $tid completed)"; pend[i]=0; rc=1; continue
      fi
      remaining=1
    done
    (( remaining )) || break
    if deadline_expired "$deadline"; then
      for i in "${!names[@]}"; do
        (( ${pend[i]} )) || continue
        statuses[i]=timeout; texts[i]="(timed out after ${timeout}s)"; pend[i]=0; rc=1
      done
      break
    fi
    sleep 1
  done

  note_uncollected_skip "${names[@]}"
  if (( json )); then
    printf '['
    for i in "${!names[@]}"; do
      (( i )) && printf ','
      emit_result_json "${tids[i]}" "${statuses[i]}" "${texts[i]}"
    done
    printf ']\n'
    return $rc
  fi
  for i in "${!names[@]}"; do
    printf '== %s (%s) %s ==\n' "${names[i]}" "${tids[i]}" "${statuses[i]}"
    printf '%s\n\n' "${texts[i]}"
  done
  # One-line verdict on stderr â€” stdout stays exactly the joined bodies so a
  # caller can still capture them cleanly. rc is set above: 0 iff every target
  # reached a valid terminal footer (done/blocked).
  local -A tally=(); local st
  for st in "${statuses[@]}"; do tally[$st]=$(( ${tally[$st]:-0} + 1 )); done
  local parts="" s
  for s in done blocked other error down timeout; do
    [[ -n ${tally[$s]:-} ]] && parts+="${parts:+ Â· }${tally[$s]} $s"
  done
  note "wait-all: ${#names[@]} task(s) â€” $parts"
  return $rc
}

# Write the steer channel atomically â€” an immediate injection the extension
# delivers into the worker's current turn (or a fresh untracked turn if idle),
# bypassing the queue. Run-now, vs `send`'s run-next.
write_steer_file() {
  local name=$1 body=$2 sf
  sf="$(state_dir)/$name.steer"
  printf '%s' "$body" > "$sf.tmp"
  mv "$sf.tmp" "$sf"
}

pi_steer_cmd() {
  local name="" src=""
  while (( $# )); do
    case $1 in
      -)  src=-; shift ;;
      -*) die "unknown flag for steer: $1" ;;
      *)
        if [[ -z $name ]]; then name=$1
        elif [[ -z $src ]]; then src=$1
        else die "extra arg: $1"; fi
        shift ;;
    esac
  done
  [[ -n $name ]] || die "steer: callsign required"
  [[ -n $src ]]  || die "steer: message source required (file path or -)"
  if [[ $src != - && ! -r $src ]]; then
    die "steer: '$src' is not a readable file. Source must be a FILE path or '-' for stdin."
  fi
  # `all` fans the steer out to every live worker.
  if [[ $name == all ]]; then
    pi_steer_all_cmd "$src"; return $?
  fi
  valid_callsign "$name" || die "invalid callsign: $name"
  require_session
  window_exists "pi-$name" || die "pi-$name does not exist"
  ensure_repl_ready "$name"
  local body
  if [[ $src == - ]]; then body=$(cat); else body=$(cat "$src"); fi
  [[ -n $body ]] || die "steer: empty message"
  write_steer_file "$name" "$body"
}

pi_steer_all_cmd() {
  local src=""
  while (( $# )); do
    case $1 in
      -)  src=-; shift ;;
      -*) die "unknown flag for steer-all: $1" ;;
      *)  [[ -z $src ]] && src=$1 || die "extra arg: $1"; shift ;;
    esac
  done
  [[ -n $src ]] || die "steer-all: message source required (file path or -)"
  if [[ $src != - && ! -r $src ]]; then
    die "steer-all: '$src' is not a readable file. Source must be a FILE path or '-' for stdin."
  fi
  require_session
  local body
  if [[ $src == - ]]; then body=$(cat); else body=$(cat "$src"); fi
  [[ -n $body ]] || die "steer-all: empty message"
  local n sent=0
  for n in "${NATO[@]}"; do
    window_exists "pi-$n" || continue
    repl_running "$n"      || continue
    write_steer_file "$n" "$body"
    printf '%s\n' "$n"
    sent=$((sent + 1))
  done
  (( sent )) || note "steer-all: no live workers"
}

# List or re-read durable task outcomes from the unified `results/` store.
#   tt pi results              all recorded tasks, newest first (table)
#   tt pi results <cs>         filtered to one worker's tasks
#   tt pi results <task-id>    print that one result's block
# --json emits a JSON array (listing) or a single envelope (task-id). This is
# the recover-an-id-you-lost path: nothing depends on having kept the id live.
pi_results_cmd() {
  local json=0 target=""
  while (( $# )); do
    case $1 in
      --json) json=1; shift ;;
      -*) die "unknown flag for results: $1" ;;
      *)  [[ -z $target ]] && target=$1 || die "extra arg: $1"; shift ;;
    esac
  done
  require_session
  local rdir="$(state_dir)/results"

  # A single task-id â†’ print (or emit) that one result.
  if [[ -n $target ]] && is_task_id "$target"; then
    local f; f=$(result_path_by_id "$target")
    [[ -f $f ]] || die "no result recorded for $target"
    local head rst text
    head=$(result_head_file "$f" 2>/dev/null || true)
    rst=${head#* }; [[ $rst == "$head" ]] && rst=""
    text=$(result_text_file "$f")
    if (( json )); then emit_result_json "$target" "$rst" "$text"; printf '\n'
    else printf '== %s (%s) ==\n%s\n' "$target" "$rst" "$text"; fi
    return 0
  fi

  # Otherwise a listing; an optional callsign filters to that worker's tasks.
  [[ -z $target ]] || valid_callsign "$target" \
    || die "results: '$target' is not a callsign or task-id"
  local -a files=()
  if [[ -d $rdir ]]; then
    local g
    while IFS= read -r g; do [[ -n $g ]] && files+=("$g"); done \
      < <(ls -1t "$rdir"/*.result 2>/dev/null || true)
  fi

  local f base head rst text sm shown=0
  if (( json )); then
    printf '['
    local first=1
    for f in "${files[@]}"; do
      base=$(basename "$f" .result)
      [[ -n $target && $base != "$target"-* ]] && continue
      head=$(result_head_file "$f" 2>/dev/null || true)
      rst=${head#* }; [[ $rst == "$head" ]] && rst=""
      text=$(result_text_file "$f")
      (( first )) || printf ','; first=0
      emit_result_json "$base" "$rst" "$text"
    done
    printf ']\n'
    return 0
  fi

  printf '%-12s  %-8s  %-6s  %s\n' TASK STATUS DUR SUMMARY
  for f in "${files[@]}"; do
    base=$(basename "$f" .result)
    [[ -n $target && $base != "$target"-* ]] && continue
    head=$(result_head_file "$f" 2>/dev/null || true)
    rst=${head#* }; [[ $rst == "$head" ]] && rst=""
    text=$(result_text_file "$f")
    sm=$(result_field "$text" summary); [[ -z $sm ]] && sm=$(result_reason_hint "$text")
    printf '%-12s  %-8s  %-6s  %s\n' "$base" "$rst" "$(result_duration_file "$f")" "${sm:0:80}"
    shown=1
  done
  (( shown )) || note "no results recorded${target:+ for $target}"
}

# Cursor-based fan-out join: return every result with turn > the per-worker
# `<cs>.collected` cursor, blocking on in-flight ones, then advance the cursor.
# Unlike `wait all` (which joins only workers busy *right now*), `collect` never
# drops a task that finished before you asked. No stuck-guard â€” bound it with
# --timeout if a worker might wedge.
pi_collect_cmd() {
  local json=0 timeout=0 target=""
  while (( $# )); do
    case $1 in
      --json) json=1; shift ;;
      --timeout) shift; [[ $# -gt 0 ]] || die "collect: --timeout requires seconds"
                 valid_timeout_arg "collect" "$1"; timeout=$1; shift ;;
      -*) die "unknown flag for collect: $1" ;;
      *)  [[ -z $target ]] && target=$1 || die "extra arg: $1"; shift ;;
    esac
  done
  require_session
  local -a targets=()
  if [[ -z $target || $target == all ]]; then
    local n; for n in "${NATO[@]}"; do window_exists "pi-$n" && targets+=("$n"); done
  else
    valid_callsign "$target" || die "collect: '$target' is not a callsign or 'all'"
    window_exists "pi-$target" || die "pi-$target does not exist"
    targets=("$target")
  fi

  local deadline=0; (( timeout > 0 )) && deadline=$(($(date +%s) + timeout))
  local -a envelopes=()
  local printed=0 cs
  for cs in "${targets[@]}"; do
    local cursor; cursor=$(cat "$(state_dir)/$cs.collected" 2>/dev/null || printf 0)
    [[ $cursor =~ ^[0-9]+$ ]] || cursor=0
    local tf="$(state_dir)/$cs.tasks.jsonl"
    [[ -s $tf ]] || continue
    local -a turns=()
    local line t
    while IFS= read -r line; do
      [[ $line == *'"id":"'* ]] || continue          # skip {"clear":N} markers
      t=$(sed -n 's/.*"turn":\([0-9]*\).*/\1/p' <<<"$line")
      [[ $t =~ ^[0-9]+$ ]] && (( t > cursor )) && turns+=("$t")
    done < "$tf"
    (( ${#turns[@]} )) || continue
    IFS=$'\n' turns=($(printf '%s\n' "${turns[@]}" | sort -n)); unset IFS
    local newcursor=$cursor id rst head text
    for t in "${turns[@]}"; do
      id="$cs-$t"; rst=""
      while true; do                                  # block until terminal
        head=$(result_head_by_id "$id" 2>/dev/null || true)
        if [[ -n $head ]]; then
          rst=${head#* }; [[ $rst == "$head" ]] && rst=""
          case "$rst" in done|blocked|other|error) break ;; esac
        fi
        repl_running "$cs" || { rst=down; break; }
        deadline_expired "$deadline" && { rst=timeout; break; }
        sleep 1
      done
      [[ $rst == timeout || $rst == down ]] && break  # stop; never skip a turn
      text=$(result_text_by_id "$id")
      if (( json )); then envelopes+=("$(emit_result_json "$id" "$rst" "$text")")
      else printf '== %s (%s) ==\n%s\n\n' "$id" "$rst" "$text"; fi
      newcursor=$t; printed=1
    done
    (( newcursor > cursor )) && printf '%s' "$newcursor" > "$(state_dir)/$cs.collected"
  done

  if (( json )); then
    printf '['; local i
    for i in "${!envelopes[@]}"; do (( i )) && printf ','; printf '%s' "${envelopes[i]}"; done
    printf ']\n'
  elif (( ! printed )); then
    note "collect: nothing new"
  fi
}

pi_status_cmd() {
  local json=0
  while (( $# )); do
    case $1 in
      --json) json=1; shift ;;
      -*) die "unknown flag for status: $1" ;;
      *)  die "status: unexpected arg: $1" ;;
    esac
  done
  require_session
  reap_ephemeral_workers

  if (( json )); then
    printf '['
    local first=1 n
    for n in "${NATO[@]}"; do
      window_exists "pi-$n" || continue
      local s tier gen last_id reason="" q el="null"
      s=$(worker_state "$n"); tier=$(current_tier "$n"); gen=$(current_gen "$n")
      last_id=$(last_task_id "$n" 2>/dev/null || true)
      q=$(queue_depth "$n")
      [[ $s == busy ]] && el=$(secs_since_file "$(state_dir)/$n.busy") || el="null"
      [[ $el =~ ^[0-9]+$ ]] || el="null"
      case $s in
        interrupted|blocked) [[ -n $last_id ]] && \
          reason=$(result_reason_hint "$(result_text_by_id "$last_id")") ;;
      esac
      (( first )) || printf ','; first=0
      printf '{"callsign":"%s","state":"%s","elapsed_s":%s,"queued":%s,"last_task":"%s","tier":"%s","gen":%s,"reason":"%s"}' \
        "$n" "$s" "$el" "$q" "$(json_escape "$last_id")" "$tier" "$gen" "$(json_escape "$reason")"
    done
    printf ']\n'
    return 0
  fi

  printf '%-9s  %-11s  %-7s  %-5s  %-12s  %-8s  %s\n' CALLSIGN STATE ELAPSED QUEUE LAST-TASK TIER    GEN
  for n in "${NATO[@]}"; do
    window_exists "pi-$n" || continue
    local s tier gen last_id="-" reason="" q el_disp="-" q_disp="-"
    s=$(worker_state "$n")
    tier=$(current_tier "$n")
    gen=$(current_gen "$n")
    local lt
    if lt=$(last_task_id "$n"); then
      last_id="$lt"
    fi
    # Elapsed: time the in-flight turn from the busy marker. Queue: pinned tasks
    # stacked behind a busy worker (a `send` to a busy worker is run-next).
    if [[ $s == busy ]]; then
      local secs; secs=$(secs_since_file "$(state_dir)/$n.busy") && el_disp=$(fmt_elapsed "$secs")
    fi
    q=$(queue_depth "$n"); [[ $q =~ ^[0-9]+$ ]] && (( q > 0 )) && q_disp="+$q"
    # interrupted/blocked carry a one-line reason from the recorded result, so
    # the recovery path is obvious without a separate `wait`/`results` call.
    case $s in
      interrupted|blocked) [[ $last_id != - ]] && \
        reason=$(result_reason_hint "$(result_text_by_id "$last_id")") ;;
    esac
    if [[ -n $reason ]]; then
      printf '%-9s  %-11s  %-7s  %-5s  %-12s  %-8s  g%-4s â€” %s\n' "$n" "$s" "$el_disp" "$q_disp" "$last_id" "$tier" "$gen" "$reason"
    else
      printf '%-9s  %-11s  %-7s  %-5s  %-12s  %-8s  g%s\n' "$n" "$s" "$el_disp" "$q_disp" "$last_id" "$tier" "$gen"
    fi
  done
  # Shared pool: tasks dispatched via `tt pi auto` while every worker was busy,
  # awaiting a free worker to steal them.
  local pooldir="$(state_dir)/queue" pending=0
  if [[ -d $pooldir ]]; then
    pending=$(find "$pooldir" -maxdepth 1 -name '*.task' 2>/dev/null | wc -l)
  fi
  if (( pending )); then
    printf 'pool: %d task(s) queued (unclaimed)\n' "$pending"
  fi
}

# Dump a worker's pi REPL pane scrollback â€” read-only observability for telling a
# turn in flight apart from a wedged one, without attaching. This does NOT drive
# the worker: the "never capture-pane" invariant is about CONTROL (claiming tasks,
# detecting completion), not a human/orchestrator reading the pane. Default 200
# lines of history; `--lines N` overrides.
pi_logs_cmd() {
  local name="" lines=200
  while (( $# )); do
    case $1 in
      --lines) shift; [[ $# -gt 0 ]] || die "logs: --lines requires a count"
               [[ $1 =~ ^[1-9][0-9]*$ ]] || die "logs: --lines must be a positive integer"
               lines=$1; shift ;;
      -*) die "unknown flag for logs: $1" ;;
      *)  [[ -z $name ]] && name=$1 || die "extra arg: $1"; shift ;;
    esac
  done
  [[ -n $name ]] || die "logs: callsign required"
  valid_callsign "$name" || die "invalid callsign: $name"
  require_session
  window_exists "pi-$name" || die "pi-$name does not exist"
  # -p print to stdout; -J join wrapped lines; -S -<n> start n lines back in
  # scrollback. Read-only â€” never sends keys.
  tmux capture-pane -p -J -S -"$lines" -t "=$(session_name):pi-$name"
}

pi_rm_cmd() {
  local name="" force=0
  while (( $# )); do
    case $1 in
      --force) force=1; shift ;;
      -*) die "unknown flag for rm: $1" ;;
      *)  [[ -z $name ]] && name=$1 || die "extra arg: $1"; shift ;;
    esac
  done
  [[ -n $name ]] || die "rm: callsign required"
  valid_callsign "$name" || die "invalid callsign: $name"
  require_session
  window_exists "pi-$name" || die "pi-$name does not exist"

  if (( ! force )) && ! ensure_idle_or_blocked "$name"; then
    die "pi-$name is busy; use --force"
  fi
  tmux kill-window -t "=$(session_name):pi-$name" 2>/dev/null || true
  rm -rf "$(state_dir)/$name."*
  rm -f  "$(state_dir)/results/$name"-*.result
  rm -rf "$(state_dir)/pi-sessions/$name"
}

pi_popidle_cmd() {
  require_session
  # Highest NATO callsign first.
  local i n
  for (( i=${#NATO[@]}-1; i>=0; i-- )); do
    n=${NATO[i]}
    window_exists "pi-$n" || continue
    if ensure_idle_or_blocked "$n"; then
      tmux kill-window -t "=$(session_name):pi-$n" 2>/dev/null || true
      rm -rf "$(state_dir)/$n."*
      rm -f  "$(state_dir)/results/$n"-*.result
      rm -rf "$(state_dir)/pi-sessions/$n"
      printf '%s\n' "$n"
      return 0
    fi
  done
  return 0
}

# Lazy single-instance drainer for the notify queue (`send`/`auto --notify`).
# Workers append `<id> <status>` files; this drains them to the orchestrator,
# coalescing everything currently pending into one paste per cycle, and exits
# once the queue stays empty briefly. Spawned detached by the worker extension;
# a redundant instance exits at once via the lock. Internal verb (not in help).
pi_notify_drain_cmd() {
  local session=${1:-}
  [[ -n $session ]] || die "notify-drain: session required"
  local sdir="$TT_STATE_DIR_BASE/$session"
  [[ -d $sdir ]] || exit 0
  local ndir="$sdir/notify" lockdir="$sdir/notify-drain.lock"

  # Single instance, stale-pid aware: a redundant drainer exits immediately.
  if ! mkdir "$lockdir" 2>/dev/null; then
    local owner; owner=$(cat "$lockdir/pid" 2>/dev/null || true)
    if [[ $owner =~ ^[0-9]+$ ]] && kill -0 "$owner" 2>/dev/null; then exit 0; fi
    rm -rf "$lockdir" 2>/dev/null || true
    mkdir "$lockdir" 2>/dev/null || exit 0
  fi
  printf '%s\n' "$$" > "$lockdir/pid"
  local lockq; printf -v lockq '%q' "$lockdir"   # bake path in: $lockdir is
  trap "rm -rf $lockq 2>/dev/null || true" EXIT   # out of scope when EXIT fires

  local idle=0
  while (( idle < 5 )); do
    # Target session gone â†’ notifications are moot; discard and stop.
    tmux has-session -t "=$session" 2>/dev/null \
      || { rm -f "$ndir"/*.msg 2>/dev/null || true; return 0; }

    local -a msgs=()
    if [[ -d $ndir ]]; then
      while IFS= read -r m; do [[ -n $m ]] && msgs+=("$m"); done \
        < <(ls "$ndir"/*.msg 2>/dev/null | sort)
    fi
    if (( ${#msgs[@]} == 0 )); then
      idle=$((idle + 1)); sleep 1; continue
    fi
    idle=0

    # No orchestrator running yet (bare shell / no claude window) â†’ leave the
    # messages for a later drainer and stop, rather than parking for the full
    # safe-input timeout against a window that will never accept input.
    local cmd=""
    if tmux list-windows -t "=$session" -F '#W' 2>/dev/null | grep -Fxq claude; then
      cmd=$(tmux display-message -t "=$session:claude" -p '#{pane_current_command}' 2>/dev/null || true)
    fi
    case "${cmd:-}" in bash|zsh|sh|fish|"") return 0 ;; esac

    # Coalesce all currently-pending messages into one paste.
    local lines="" count=0 m line
    for m in "${msgs[@]}"; do
      line=$(cat "$m" 2>/dev/null) || continue
      lines+="$line"$'\n'; count=$((count + 1))
    done
    local msg
    if (( count == 1 )); then
      msg="[tt] ${lines%$'\n'}"
    else
      msg="[tt] $count tasks finished:"$'\n'"${lines%$'\n'}"
    fi

    # Deliver in a subshell so x_deliver's die (lock/input timeout) does not
    # kill the drainer. Success â†’ drop the delivered messages. Failure â†’ leave
    # them for a later drainer and stop (avoid spinning).
    if ( x_deliver "$session" "$msg" 300 ); then
      for m in "${msgs[@]}"; do rm -f "$m"; done
    else
      return 0
    fi
  done
}

# Run `pi update` against the worker's private config dir
# (PI_CODING_AGENT_DIR=$TT_PI_WORKER_DIR), so extensions installed into the
# worker pool get updated â€” not the orchestrator's own pi config. Forwards
# all args and exit code; no `tt` session required.
pi_update_cmd() {
  ensure_pi_worker_dir
  PI_CODING_AGENT_DIR="$TT_PI_WORKER_DIR" exec pi update "$@"
}

# ---------- cross-session messaging ----------

x_target_state_dir() {
  local target=$1 d="$TT_STATE_DIR_BASE/$target"
  [[ -d $d ]] || die "x send: no state dir for session: $target"
  printf '%s' "$d"
}

valid_timeout_arg() {
  local context=$1 value=$2
  [[ $value =~ ^[0-9]+$ ]] || die "$context: --timeout must be a non-negative integer"
}

deadline_expired() {
  local deadline=$1
  [[ $deadline != 0 && $(date +%s) -ge $deadline ]]
}

x_acquire_lock() {
  local target=$1 deadline=$2
  local lockdir; lockdir="$(x_target_state_dir "$target")/x-send.lock"
  local noted=0 owner=""

  while ! mkdir "$lockdir" 2>/dev/null; do
    if [[ -r $lockdir/pid ]]; then
      owner=$(cat "$lockdir/pid" 2>/dev/null || true)
      if [[ $owner =~ ^[0-9]+$ ]] && ! kill -0 "$owner" 2>/dev/null; then
        rm -rf "$lockdir" 2>/dev/null || true
        continue
      fi
    fi
    (( noted )) || { note "x send: waiting behind another send to $target; Ctrl-C cancels"; noted=1; }
    deadline_expired "$deadline" && die "x send: timed out waiting for x-send lock for $target"
    sleep 0.5
  done

  printf '%s\n' "$$" > "$lockdir/pid"
  printf '%s\n' "$(session_name)" > "$lockdir/from"
  date +%s > "$lockdir/created_at"
  printf '%s' "$lockdir"
}

x_classify_claude_input() {
  local target=$1 plain escaped prompt after stripped esc suggestion_re cursor_suggestion_re
  X_CLASSIFIER="capture_error"
  X_UNSAFE_MARKER=""
  X_PROMPT_PLAIN=""
  X_PROMPT_ESCAPED=""
  X_STRIPPED_AFTER=""

  plain=$(tmux capture-pane -p -S -12 -t "=$target:claude" 2>/dev/null) || { printf '%s\n' "$X_CLASSIFIER"; return 0; }
  if grep -Eiq 'esc interrupt|ctrl\+c cancel|ctrl\+c to cancel' <<<"$plain"; then
    X_CLASSIFIER="wait_active"; X_UNSAFE_MARKER="interrupt/cancel"; printf '%s\n' "$X_CLASSIFIER"; return 0
  fi
  if grep -Eiq 'queued messages?|paste again to expand' <<<"$plain"; then
    X_CLASSIFIER="safe_queued"; X_UNSAFE_MARKER="queued-message"; printf '%s\n' "$X_CLASSIFIER"; return 0
  fi
  if grep -Eiq 'Churning|Blanching' <<<"$plain"; then
    X_CLASSIFIER="wait_active"; X_UNSAFE_MARKER="active-status"; printf '%s\n' "$X_CLASSIFIER"; return 0
  fi

  escaped=$(tmux capture-pane -e -p -S -8 -t "=$target:claude" 2>/dev/null) || { printf '%s\n' "$X_CLASSIFIER"; return 0; }
  prompt=$(awk '/âťŻ/{line=$0} END{if (line != "") print line; else exit 1}' <<<"$escaped") || {
    X_CLASSIFIER="wait_no_prompt"; printf '%s\n' "$X_CLASSIFIER"; return 0
  }
  X_PROMPT_ESCAPED=$(perl -pe 's/\e/\\e/g' <<<"$prompt")
  X_PROMPT_PLAIN=$(awk '/âťŻ/{line=$0} END{print line}' <<<"$plain")
  after=${prompt#*âťŻ}

  # Empty input is only spaces/NBSP plus optional terminal reset codes.
  stripped=$(perl -pe 's/\e\[[0-9;?]*[ -\/]*[@-~]//g' <<<"$after")
  X_STRIPPED_AFTER=$stripped
  if [[ $stripped =~ ^[[:space:]Â ]*$ ]]; then
    X_CLASSIFIER="safe_empty"; printf '%s\n' "$X_CLASSIFIER"; return 0
  fi

  # Real user input can be styled too; only explicit dim text is treated
  # as Claude Code suggestion text that paste replaces. Claude can render
  # the cursor-highlighted first suggestion char as reverse-video, then dim.
  esc=$'\033'
  suggestion_re="^[[:space:]Â ]*${esc}\\[2m"
  cursor_suggestion_re="^[[:space:]Â ]*${esc}\\[7m.${esc}\\[0;2m"
  if [[ $after =~ $suggestion_re || $after =~ $cursor_suggestion_re ]]; then
    X_CLASSIFIER="safe_suggestion"; printf '%s\n' "$X_CLASSIFIER"; return 0
  fi

  X_CLASSIFIER="wait_real_input"
  printf '%s\n' "$X_CLASSIFIER"
}

x_claude_accepts_input() {
  local classifier
  classifier=$(x_classify_claude_input "$1")
  case "$classifier" in
    safe_empty|safe_suggestion|safe_queued) return 0 ;;
    *) return 1 ;;
  esac
}

x_wait_claude_accepts_input() {
  local target=$1 deadline=$2 noted=0
  while ! x_claude_accepts_input "$target"; do
    (( noted )) || { note "x send: waiting for $target:claude safe input; Ctrl-C cancels"; noted=1; }
    deadline_expired "$deadline" && die "x send: timed out waiting for $target:claude safe input"
    sleep 0.5
  done
}

# Send a message to another tt session's orchestrator (the Claude Code
# TUI in its `claude` window) and submit it. Unlike pi workers, the
# orchestrator has no file control channel â€” delivery is a tmux
# bracketed paste (multiline-safe) followed by Enter, guarded by a
# conservative safe-input prompt check so Enter is not pressed in a
# user's draft, a confirmation UI, or an in-flight turn.
x_send_cmd() {
  local target="" src="" timeout=0
  while (( $# )); do
    case $1 in
      --timeout)
        shift; [[ $# -gt 0 ]] || die "x send: --timeout requires seconds"
        valid_timeout_arg "x send" "$1"; timeout=$1; shift ;;
      -)  src=-; shift ;;
      -*) die "unknown flag for x send: $1" ;;
      *)
        if [[ -z $target ]]; then target=$1
        elif [[ -z $src ]]; then src=$1
        else die "extra arg: $1"; fi
        shift ;;
    esac
  done
  [[ -n $target ]] || die "x send: session id required"
  [[ -n $src ]]    || die "x send: message source required (file path or -)"
  if [[ $src != - && ! -r $src ]]; then
    die "x send: '$src' is not a readable file. Source must be a FILE path or '-' for stdin.
  echo text:   printf 'hello\n' | tt x send <id> -
  from a file: tt x send <id> ./msg.txt"
  fi

  tmux has-session -t "=$target" 2>/dev/null \
    || die "x send: no tmux session: $target"
  x_target_state_dir "$target" >/dev/null
  tmux list-windows -t "=$target" -F '#W' 2>/dev/null | grep -Fxq claude \
    || die "x send: session $target has no claude window"

  # Refuse if the orchestrator is not actually running (bare shell).
  local cmd
  cmd=$(tmux display-message -t "=$target:claude" -p '#{pane_current_command}' 2>/dev/null) \
    || die "x send: cannot inspect $target:claude"
  case "$cmd" in
    bash|zsh|sh|fish) die "x send: orchestrator not running in $target (bare shell)" ;;
  esac

  local body
  if [[ $src == - ]]; then body=$(cat); else body=$(cat "$src"); fi
  [[ -n $body ]] || die "x send: empty message"

  # Prepend an attribution header so the receiver knows it is
  # cross-session traffic and who it came from.
  local msg
  msg=$(printf '[tt x from %s]\n%s' "$(session_name)" "$body")
  x_deliver "$target" "$msg" "$timeout"
}

# Deliver a message into <target>'s claude pane: take the per-target send lock,
# wait for a safe-input state, bracketed-paste (newline-safe), then submit with
# one Enter. Shared by `tt x send` and the notify drainer. Dies on lock/input
# timeout (a caller that must not die â€” the drainer â€” runs it in a subshell).
# timeout 0 = wait forever.
x_deliver() {
  local target=$1 msg=$2 timeout=$3
  local deadline=0
  (( timeout > 0 )) && deadline=$(($(date +%s) + timeout))

  local lockdir
  lockdir=$(x_acquire_lock "$target" "$deadline")
  local lockq
  printf -v lockq '%q' "$lockdir"
  trap "rm -rf $lockq 2>/dev/null || true" EXIT

  x_wait_claude_accepts_input "$target" "$deadline"

  local buf="tt-x-$$"
  printf '%s' "$msg" | tmux load-buffer -b "$buf" -
  tmux paste-buffer -d -p -b "$buf" -t "=$target:claude"
  sleep 0.3
  tmux send-keys -t "=$target:claude" Enter
}

x_list_cmd() {
  local show_all=0
  while (( $# )); do
    case $1 in
      --all) show_all=1; shift ;;
      -*) die "unknown flag for x list: $1" ;;
      *) die "x list: unexpected argument: $1" ;;
    esac
  done

  local base="${TT_STATE_DIR_BASE}"
  local found=0

  if (( show_all )); then
    printf '%-20s  %-15s  %s\n' SESSION STATUS PWD
  else
    printf '%-20s  %s\n' SESSION PWD
  fi

  for dir in "$base"/*/; do
    [[ -d $dir ]] || continue
    local sname
    sname=$(basename "$dir")
    local pwd_val
    pwd_val=$(cat "$dir/project" 2>/dev/null || printf '%s' '-')

    # Check tmux session liveness
    if ! tmux has-session -t "=$sname" 2>/dev/null; then
      if (( show_all )); then
        printf '%-20s  %-15s  %s\n' "$sname" "down" "$pwd_val"
        found=1
      fi
      continue
    fi

    # Check if claude window exists and orchestrator is running
    local status="no-orchestrator"
    if tmux list-windows -t "=$sname" -F '#W' 2>/dev/null | grep -Fxq claude; then
      local pane_cmd
      pane_cmd=$(tmux display-message -t "=$sname:claude" -p '#{pane_current_command}' 2>/dev/null) || true
      case "${pane_cmd:-}" in
        bash|zsh|sh|fish|"") status="no-orchestrator" ;;
        *) status="ready" ;;
      esac
    fi

    if (( show_all )); then
      printf '%-20s  %-15s  %s\n' "$sname" "$status" "$pwd_val"
      found=1
    elif [[ $status == ready ]]; then
      printf '%-20s  %s\n' "$sname" "$pwd_val"
      found=1
    fi
  done

  if (( ! found )); then
    if (( show_all )); then
      printf '(no tt sessions found)\n'
    else
      printf '(no tt sessions with a live orchestrator)\n'
    fi
  fi
}

x_observe_db_default() {
  printf '%s/x-observe.sqlite' "$TT_STATE_DIR_BASE"
}

x_observe_require_sqlite() {
  command -v sqlite3 >/dev/null 2>&1 || die "x observe: sqlite3 is required"
}

x_observe_init_db() {
  local db=$1
  mkdir -p "$(dirname "$db")"
  sqlite3 "$db" >/dev/null <<'SQL'
PRAGMA journal_mode=WAL;
CREATE TABLE IF NOT EXISTS x_observe_events (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  ts INTEGER NOT NULL,
  session TEXT NOT NULL,
  status TEXT NOT NULL,
  project TEXT NOT NULL,
  pane_cmd TEXT NOT NULL,
  classifier TEXT NOT NULL,
  unsafe_marker TEXT NOT NULL,
  plain_tail TEXT NOT NULL,
  escaped_tail TEXT NOT NULL,
  prompt_plain TEXT NOT NULL,
  prompt_escaped_visible TEXT NOT NULL,
  stripped_after_prompt TEXT NOT NULL,
  payload_key TEXT NOT NULL UNIQUE
);
CREATE INDEX IF NOT EXISTS x_observe_events_ts_idx ON x_observe_events(ts);
CREATE INDEX IF NOT EXISTS x_observe_events_classifier_idx ON x_observe_events(classifier);
CREATE INDEX IF NOT EXISTS x_observe_events_session_idx ON x_observe_events(session);
SQL
}

x_observe_payload_key() {
  perl -MJSON::PP -MDigest::SHA=sha1_hex -e '
    my @names = qw(session status project pane_cmd classifier unsafe_marker plain_tail escaped_tail prompt_plain prompt_escaped_visible stripped_after_prompt);
    my %obj;
    @obj{@names} = @ARGV;
    print sha1_hex(JSON::PP->new->ascii->canonical->encode(\%obj));
  ' "$@"
}

x_observe_insert() {
  local db=$1 ts=$2 session=$3 status=$4 project=$5 pane_cmd=$6 classifier=$7 unsafe=$8 plain=$9 escaped=${10} prompt_plain=${11} prompt_escaped=${12} stripped=${13}
  local payload_key
  payload_key=$(x_observe_payload_key "$session" "$status" "$project" "$pane_cmd" "$classifier" "$unsafe" "$plain" "$escaped" "$prompt_plain" "$prompt_escaped" "$stripped")
  perl -CS -e '
    sub sql_quote {
      my ($s) = @_;
      $s =~ s/\x27/\x27\x27/g;
      return chr(39) . $s . chr(39);
    }
    my @v = @ARGV;
    print "INSERT OR IGNORE INTO x_observe_events (ts, session, status, project, pane_cmd, classifier, unsafe_marker, plain_tail, escaped_tail, prompt_plain, prompt_escaped_visible, stripped_after_prompt, payload_key) VALUES (";
    print join(",", $v[0], map { sql_quote($_) } @v[1..12]);
    print ");\n";
  ' "$ts" "$session" "$status" "$project" "$pane_cmd" "$classifier" "$unsafe" "$plain" "$escaped" "$prompt_plain" "$prompt_escaped" "$stripped" "$payload_key" \
    | sqlite3 "$db"
}

x_observe_event() {
  local db=$1 session=$2 status=$3 project=$4 pane_cmd=$5 classifier=$6 unsafe=$7 plain=$8 escaped=$9 prompt_plain=${10} prompt_escaped=${11} stripped=${12}
  local ts
  ts=$(date +%s)
  x_observe_insert "$db" "$ts" "$session" "$status" "$project" "$pane_cmd" "$classifier" "$unsafe" "$plain" "$escaped" "$prompt_plain" "$prompt_escaped" "$stripped"
}

x_observe_run_cmd() {
  local interval=1 duration=0 db="" show_all=0
  while (( $# )); do
    case $1 in
      --interval)
        shift; [[ $# -gt 0 ]] || die "x observe: --interval requires seconds"
        valid_timeout_arg "x observe" "$1"; (( $1 > 0 )) || die "x observe: --interval must be greater than 0"; interval=$1; shift ;;
      --duration)
        shift; [[ $# -gt 0 ]] || die "x observe: --duration requires seconds"
        valid_timeout_arg "x observe" "$1"; duration=$1; shift ;;
      --all) show_all=1; shift ;;
      -*) die "unknown flag for x observe: $1" ;;
      *) die "x observe: unexpected argument: $1" ;;
    esac
  done
  [[ -n $db ]] || db=$(x_observe_db_default)
  x_observe_require_sqlite
  x_observe_init_db "$db"

  local deadline=0
  (( duration > 0 )) && deadline=$(($(date +%s) + duration))
  note "x observe: logging Claude pane captures to $db; Ctrl-C stops collection"

  while true; do
    local dir
    for dir in "$TT_STATE_DIR_BASE"/*/; do
      [[ -d $dir ]] || continue
      local sname project pane_cmd status plain escaped classifier
      sname=$(basename "$dir")
      project=$(cat "$dir/project" 2>/dev/null || printf '%s' '-')
      status="ready"
      pane_cmd=""
      plain=""
      escaped=""
      classifier=""
      X_UNSAFE_MARKER=""; X_PROMPT_PLAIN=""; X_PROMPT_ESCAPED=""; X_STRIPPED_AFTER=""

      if ! tmux has-session -t "=$sname" 2>/dev/null; then
        (( show_all )) || continue
        status="down"; classifier="not_observed"
      elif ! tmux list-windows -t "=$sname" -F '#W' 2>/dev/null | grep -Fxq claude; then
        (( show_all )) || continue
        status="no-claude-window"; classifier="not_observed"
      else
        pane_cmd=$(tmux display-message -t "=$sname:claude" -p '#{pane_current_command}' 2>/dev/null || true)
        case "${pane_cmd:-}" in
          bash|zsh|sh|fish|"")
            (( show_all )) || continue
            status="no-orchestrator"; classifier="not_observed" ;;
          *)
            x_classify_claude_input "$sname" >/dev/null
            classifier=$X_CLASSIFIER
            plain=$(tmux capture-pane -p -S -12 -t "=$sname:claude" 2>/dev/null || true)
            escaped=$(tmux capture-pane -e -p -S -8 -t "=$sname:claude" 2>/dev/null | perl -pe 's/\e/\\e/g' || true) ;;
        esac
      fi
      x_observe_event "$db" "$sname" "$status" "$project" "$pane_cmd" "$classifier" "$X_UNSAFE_MARKER" "$plain" "$escaped" "$X_PROMPT_PLAIN" "$X_PROMPT_ESCAPED" "$X_STRIPPED_AFTER"
    done

    deadline_expired "$deadline" && return 0
    sleep "$interval"
  done
}

x_observe_cmd() {
  local sub=${1:-run}
  case "$sub" in
    run) shift || true; x_observe_run_cmd "$@" ;;
    --*|-*|"") x_observe_run_cmd "$@" ;;
    *) die "unknown x observe subcommand '$sub' (try \`tt --help\`)" ;;
  esac
}

# ---------- help ----------

print_help() {
  cat <<'HELP'
tt â€” tmux team: per-project tmux session with a pi worker pool

USAGE
  tt [VERB] [ARGS...]

SESSION VERBS
  tt                       Alias for `tt up`.
  tt up                    Idempotent. Compute session name from $PWD;
                           create the session and standard windows if
                           missing; attach.
  tt a, tt attach          Attach without creating. Errors if missing.
  tt name                  Print computed session name (for scripts).
  tt down                  Kill the session for $PWD (with confirmation).
  tt --help, -h            This help.
  tt --version, -v         Print version.

PI WORKER VERBS
  The pool is lazy: `tt up` pre-spawns nothing. A worker's pi REPL is
  created on first use â€” `tt pi send <cs>` / `tt pi auto` spawn it on
  demand (up to the cap, cores-2, max 26). Callsigns are NATO
  (alfaâ†’bravoâ†’â€¦â†’zulu); none is special.

  tt pi clear [--force] <callsign>
      Wipe the worker's context: bumps a generation counter and respawns
      the pi REPL on a fresh session-dir. Refuses unless idle/blocked;
      --force interrupts a busy turn first.

  tt pi resume <callsign>
      Recover an INTERRUPTED worker WITHOUT a context wipe: re-drive its
      interrupted task to completion (interrupted â†’ busy â†’ done). Use this when
      a turn was interrupted (you hit Esc, typed into the pane, â€¦) but the REPL
      is alive and its context is intact â€” unlike `clear`, it keeps that context.
      Requires the REPL to be running and the worker to be interrupted. The turn
      runs asynchronously; join it with `tt pi wait <callsign>`. (In the worker's
      own pane you can instead type `/tt-resume`.)

  tt pi send [--tier NAME] [--notify] <callsign> (FILE | -)
      Send a prompt to the worker's live pi REPL. Source is a file path,
      or `-` for stdin â€” feed inline text with a here-string or heredoc:
      `tt pi send alfa - <<<'TASK: ...'`.
      Pass --tier NAME to choose the model preset (see "Thinking tier"
      below). A send to an absent worker lazily spawns it (under the cap).
      A send to a BUSY worker queues behind the current turn (run-next;
      use `tt pi steer` for run-now). --notify: on completion, ping this
      session's orchestrator (see below). Prints task-id (e.g. "alfa-3").

  tt pi auto [--tier NAME] [--prefer-fresh] [--rm] [--notify] [--json] (FILE | -)
      Dispatch without naming a worker: reuse an idle worker, else spawn one
      (under the cap), else queue on the shared pool where the first worker
      to go idle steals it. Echoes "using pi-<cs>" to stderr; prints the
      task-id to stdout (`<cs>-<n>` when assigned, `pool-<n>` when pooled), so
      `TID=$(tt pi auto - <<<'TASK: ...')` captures just the id. Pass
      --tier NAME to choose the model preset (see "Thinking tier" below).
      With --prefer-fresh, spawn a NEW worker before reusing an idle one (as
      long as the cap allows) â€” for eager parallelism and a clean pi context,
      since a reused idle worker still carries its previous task's context.
      With --rm, instead spawn a fresh EPHEMERAL worker that is torn down once
      its task (and any pinned follow-ups) finish â€” a clean one-shot. An
      ephemeral worker never steals pool work, and is reaped on the next
      auto/status or on its own `wait`. (--rm implies fresh, so it wins over
      --prefer-fresh.) --json prints one line instead of the stderr/stdout
      split: {"worker","task_id","routed"} where routed is the actual
      placement (idle|spawn|pool|ephemeral). --notify: see below.

  Thinking tier
      A "tier" is a named preset that bundles (model, thinking effort).
      The effort is fixed per tier and cannot be set independently â€” the
      legacy --low/--medium/--high/--xhigh flags are rejected. Two tiers
      are defined (both via the opencode-go provider):

        deepseek  default. opencode-go/deepseek-v4-flash at xhigh effort.
                  Cost-efficient default for high-volume, structured work.
        minimax   opencode-go/minimax-m3 at high effort. Premium tier â€”
                  pick for harder, longer-horizon, or more judgment-heavy
                  work where the model's higher base capability earns
                  its way past the lower thinking effort.

      Pick a tier per dispatch with --tier NAME on `send`/`auto`. Omit
      --tier to keep the worker's current tier. A fresh worker starts on
      the default (deepseek). Tier change on a running worker is
      REFUSED (the model is baked into the REPL's --model at launch) â€”
      the error points at `tt pi clear <cs>`, which respawns the REPL
      on the new tier (loses context, like a normal clear). For
      `auto --tier NAME`, a non-matching idle worker is skipped and a
      fresh worker is spawned (under cap) instead. See
      references/prompting-deepseek.md and references/prompting-minimax.md
      for per-tier prompting guidance.

  --notify (on send / auto)
      Fire-and-forget completion ping: when the task finishes, the worker
      appends to a notify queue and a single lazily-started drainer pastes a
      "[tt] <id> <status>" line into this session's `claude` pane (coalescing
      multiple completions into one message). The worker never waits on
      delivery; use it to dispatch without blocking on `wait`.

  tt pi steer <callsign|all> (FILE | -)
      Inject a message NOW â€” steered into the worker's current turn (or a
      fresh turn if idle), bypassing the queue. Unlike `send`, it is not a
      tracked task (no task-id, no result of its own). `all` fans the
      message out to every live worker.

  tt pi wait [--timeout SECONDS] [--json] <callsign|task-id|pool-id|all> [task-id]
      Block until the task's result is recorded. The target may be a callsign
      (waits on its latest dispatch â€” task-id optional), a bare task-id like
      `alfa-3` (callsign derived), a `pool-<n>` id (a `tt pi auto` pool task),
      or `all` (join every busy worker, one consolidated report). Any task-id
      resolves â€” even an older one whose latest-pointer has since advanced â€”
      because results are read from the per-id store. By default it waits
      forever; Ctrl-C cancels. --timeout SECONDS bounds it (--timeout 0 also
      waits forever); a worker task left queued on an idle worker fails fast at
      20s (a pool task has no such guard â€” it waits for capacity). Prints the
      WORKER_DONE / BLOCKED block, or with --json a result envelope
      ({id,status,summary,files_changed,notes,reason,started_at,ended_at,
      duration_s}; an array for `all`).
      Exit 0 on done/blocked, non-zero on timeout / unexpected completion.
      `all` prints a one-line tally on stderr (e.g. `2 done Â· 1 other`) and
      exits non-zero if any joined worker ended error/other/down/timeout. If a
      non-busy worker holds a result that finished before the join (so `all`
      skipped it), a stderr hint points at `tt pi collect`.

  tt pi collect [--timeout SECONDS] [--json] [all|<callsign>]
      Fan-out join that never drops a finished task. Returns every result with
      turn greater than the per-worker collected cursor â€” blocking on any still
      in flight â€” then advances the cursor. Unlike `wait all` (which joins only
      workers busy right now), a task that finished before you asked is still
      collected. Default target is every existing worker; name one to scope it.
      --json emits an array of result envelopes. No stuck-guard â€” bound a
      possibly-wedged worker with --timeout.

  tt pi results [--json] [<callsign>|<task-id>]
      Read durable task outcomes from the per-id store. No argument lists every
      recorded task (newest first); a callsign filters to that worker; a task-id
      prints that one result's block. --json emits an array (listing) or a
      single envelope (task-id). The recover-an-id-you-lost path â€” nothing
      depends on having kept the id from the original dispatch.

  tt pi status [--json]
      One row per existing worker: CALLSIGN, STATE
      (idle/busy/blocked/interrupted/down/missing), ELAPSED (in-flight turn time
      for a busy worker, M:SS), QUEUE (pinned tasks stacked behind it, "+N"),
      LAST-TASK, TIER, GEN. interrupted/blocked rows carry a one-line reason from
      the recorded result. --json emits an array of
      {callsign,state,elapsed_s,queued,last_task,tier,gen,reason} (elapsed_s is
      null unless busy).

  tt pi logs [--lines N] <callsign>
      Dump the worker's pi REPL pane scrollback to stdout (default 200 lines;
      --lines N for more) â€” read-only, to tell an in-flight turn from a wedged
      one without attaching. It does not drive the worker.

  tt pi rm [--force] <callsign>
  tt pi remove [--force] <callsign>
      Remove a worker (kill its REPL + window, wipe its state incl. its durable
      results). Refuses unless idle/blocked without --force.

  tt pi popidle
      Remove the highest-NATO idle worker. No-op if none idle. Prints the
      removed callsign.

  tt pi update [<args>...]
      Run `pi update` against the worker's private config dir
      (PI_CODING_AGENT_DIR=$TT_PI_WORKER_DIR), so extensions installed in
      the worker pool get updated â€” not the orchestrator's own pi config.
      All args are forwarded (e.g. `tt pi update --self`, `tt pi update
      --extensions`, `tt pi update <source>`); exit code passes through.
      No tt session required.

CROSS-SESSION VERBS
  tt x send [--timeout SECONDS] <session-id> (FILE | -)
      Send a message to another tt session's orchestrator (its live
      Claude Code TUI) and submit it as one turn once Claude Code can
      safely accept input: empty prompt, suggestion prompt, or queued-message
      state. By default it waits forever; Ctrl-C cancels. Use
      --timeout SECONDS to fail instead of waiting indefinitely.
      Source is a file path, or `-` for stdin (here-string or heredoc):
      `tt x send brainstorm-a3f1 - <<<'hi'`.
      <session-id> is the exact tmux session name; run `tt name` in the
      other project to get it. The message is prefixed `[tt x from
      <sender>]` so the receiver sees it is cross-session traffic.
      Refuses if the session is missing or its orchestrator is not
      running.
      Send-only: there is no `tt x receive`. Concurrent sends to the same
      target are serialized; the other session replies by running its own
      `tt x send` back to you, which arrives as a new turn in your session.

  tt x ls [--all]
  tt x list [--all]
      List tt sessions available to message. By default shows only sessions
      where the orchestrator (Claude Code TUI) is actively running. With
      --all, shows every session whose state dir exists, with a STATUS
      column (ready / no-orchestrator / down).

  tt x observe [run] [--interval SECONDS] [--duration SECONDS] [--all]
      Passively sample Claude Code panes to improve `tt x send` safe-input
      detection. Writes SQLite to ${XDG_STATE_HOME:-$HOME/.local/state}/tt/x-observe.sqlite,
      including plain and escaped pane tails plus the classifier used by
      `tt x send`. Default interval is 1s; duration 0 means run until
      Ctrl-C. Duplicate non-ts payloads are ignored. --all logs
      down/no-orchestrator sessions as metadata rows.

WINDOW LAYOUT
  0  dev          Empty shell in $PWD. Run the dev server here.
  1  claude       Shell; `claude --continue` auto-launched on `tt up`.
  pi-<cs>         Live pi REPL, created on demand by `tt pi send`/`auto`
                  (NATO alfaâ€¦zulu, cap cores-2 max 26). None pre-spawned.
  +  user windows Ad-hoc, created with Ctrl-b c. Not managed by tt.

  Pi windows host a live, interactive pi REPL. `tt pi send` appends to a
  per-worker queue (`<cs>.queue/`) that the worker-installed `tt-worker`
  extension drains when idle; `tt pi wait` reads the result the extension
  records. You can watch, type into, and steer any pi-* REPL by hand â€” tt's
  file channel and your keystrokes coexist.

SESSION NAMING
  <basename($PWD)>-<sha1($PWD)[:4]>     e.g. /home/me/proj/foo â†’ foo-a3f1

STATE
  $XDG_STATE_HOME/tt/<session>/version                  tt version last stamped by `tt up`
  $XDG_STATE_HOME/tt/<session>/project                  project directory for this session
  $XDG_STATE_HOME/tt/<session>/<callsign>.tasks.jsonl   per-worker task log
  $XDG_STATE_HOME/tt/<session>/<callsign>.tier          current pi thinking tier
  $XDG_STATE_HOME/tt/<session>/<callsign>.gen           current context generation
  $XDG_STATE_HOME/tt/<session>/<callsign>.in.<N>.txt    prompt body for turn N
  $XDG_STATE_HOME/tt/<session>/<callsign>.queue/        per-worker task queue (<turn>.task)
  $XDG_STATE_HOME/tt/<session>/<callsign>.steer         run-now injection (tt pi steer)
  $XDG_STATE_HOME/tt/<session>/<callsign>.resume        resume trigger (tt pi resume / /tt-resume)
  $XDG_STATE_HOME/tt/<session>/<callsign>.result        worker's latest-turn result (liveness pointer)
  $XDG_STATE_HOME/tt/<session>/<callsign>.collected     tt pi collect cursor (last collected turn)
  $XDG_STATE_HOME/tt/<session>/<callsign>.busy          marker: REPL is processing a turn
  $XDG_STATE_HOME/tt/<session>/<callsign>.ready         REPL queue-pump + steer-watch are live
  $XDG_STATE_HOME/tt/<session>/queue/                   shared pool queue (<seq>.task, tt pi auto)
  $XDG_STATE_HOME/tt/<session>/results/                 unified per-id result store (<id>.result, named + pool)
  $XDG_STATE_HOME/tt/<session>/notify/                  --notify completion queue (drained to orchestrator)
  $XDG_STATE_HOME/tt/<session>/pi-sessions/<callsign>/g<N>/   pi session-dir

EXIT CODES
  0   success
  1   invalid usage / refused operation / pi exited unexpectedly
  >1  wait timeout

EXAMPLES
  # Open / attach the project session
  tt

  # Send a heredoc to alfa
  tt pi send alfa - <<'PROMPT'
TASK: rename `foo` to `bar` in app/root.tsx
FILES: app/root.tsx
CHANGE: rename the local variable only; do not touch other identifiers.
SUCCESS: `pnpm typecheck` passes; no other diffs.
PROMPT

  # Send, then wait on the worker's latest task (task-id optional)
  tt pi send bravo - <<<'TASK: ...'
  tt pi wait bravo                   # waits on bravo's latest dispatch

  # Queue a follow-up on a busy worker (runs next); or steer it NOW
  tt pi send  bravo - <<<'TASK: then update the test'   # run-next
  tt pi steer bravo - <<<'also keep the old export'     # run-now, this turn

  # See who's free
  tt pi status

  # Let tt pick the worker (idle â†’ spawn â†’ pool); wait on the returned id
  TID=$(tt pi auto - <<<'TASK: ...')   # stderr: "using pi-bravo"
  tt pi wait "$TID"                    # works for alfa-3 or pool-3 alike

  # Fan out distinct tasks, then join them all in one call
  tt pi send alfa  - <<<'TASK: ...'
  tt pi send bravo - <<<'TASK: ...'
  tt pi wait all                     # one round-trip; joins all busy workers
  tt pi collect                      # or: drain every finished-but-uncollected result

  # Re-read a past outcome you no longer have the id for; machine-readable too
  tt pi results                      # all recorded tasks, newest first
  tt pi results alfa-3 --json        # one envelope: {id,status,summary,files_changed,...}

  # One-shot on a fresh ephemeral worker (reaped after)
  TID=$(tt pi auto --rm - <<<'TASK: ...')
  tt pi wait "$TID"

  # You interrupted a worker (Esc / typed in its pane) â†’ it's now `interrupted`.
  # Resume the same task with its context intact (no wipe), then join it.
  tt pi resume alfa                  # or type /tt-resume in the pi-alfa pane
  tt pi wait alfa                    # interrupted â†’ busy â†’ done
HELP
}

# ---------- dispatch ----------

cmd=${1:-}; (( $# > 0 )) && shift || true
case "$cmd" in
  ""|up)            up_cmd ;;
  a|attach)         attach_cmd ;;
  name)             printf '%s\n' "$(session_name)" ;;
  down)             down_cmd ;;
  -h|--help)        print_help ;;
  -v|--version)     printf 'tt %s\n' "$VERSION" ;;
  pi)
    sub=${1:-}; (( $# > 0 )) && shift || true
    case "$sub" in
      clear)    pi_clear_cmd "$@" ;;
      resume)   pi_resume_cmd "$@" ;;
      send)     pi_send_cmd "$@" ;;
      auto)     pi_auto_cmd "$@" ;;
      notify-drain) pi_notify_drain_cmd "$@" ;;
      steer)    pi_steer_cmd "$@" ;;
      steer-all) pi_steer_all_cmd "$@" ;;
      wait)     pi_wait_cmd "$@" ;;
      wait-all) pi_wait_all_cmd "$@" ;;
      status)   pi_status_cmd "$@" ;;
      logs)     pi_logs_cmd "$@" ;;
      results)  pi_results_cmd "$@" ;;
      collect)  pi_collect_cmd "$@" ;;
      rm|remove) pi_rm_cmd "$@" ;;
      popidle)  pi_popidle_cmd "$@" ;;
      update)   pi_update_cmd "$@" ;;
      "")       die "pi: subcommand required (try \`tt --help\`)" ;;
      *)        die "unknown pi subcommand '$sub' (try \`tt --help\`)" ;;
    esac ;;
  x)
    sub=${1:-}; (( $# > 0 )) && shift || true
    case "$sub" in
      send)     x_send_cmd "$@" ;;
      ls|list)  x_list_cmd "$@" ;;
      observe)  x_observe_cmd "$@" ;;
      "")       die "x: subcommand required (try \`tt --help\`)" ;;
      *)        die "unknown x subcommand '$sub' (try \`tt --help\`)" ;;
    esac ;;
  *) die "unknown verb '$cmd' (try \`tt --help\`)" ;;
esac
